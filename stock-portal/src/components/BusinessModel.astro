---
import ValueChainDiagram from './ValueChainDiagram.astro';

interface StructuralItem {
  item: string;
  value: number;
}

interface ValueChainItem {
  item: string;
  ratio: string | number;
  description: string;
}

interface Props {
  symbol: string;
  revenueStruct: StructuralItem[];
  profitStruct: StructuralItem[];
  inputs: ValueChainItem[];
  production: ValueChainItem[];
  outputs: ValueChainItem[];
  others?: string | null;
}

const { 
  symbol,
  revenueStruct = [], 
  profitStruct = [], 
  inputs = [], 
  production = [], 
  outputs = [],
  others = null
} = Astro.props;

// Mock business analysis details based on symbol (resilient, high quality data)
interface ParsedRow {
  type: 'highlight' | 'warning' | 'info';
  label: string;
  content: string;
}

const parseOthers = (othersText: string | null | undefined): ParsedRow[] => {
  if (!othersText) return [];
  return othersText
    .split('\n')
    .map(line => line.trim())
    .filter(line => line.startsWith('-'))
    .map(line => {
      let content = line.substring(1).trim();
      if (content.startsWith('*')) {
        content = content.substring(1).trim();
      }
      
      let type: 'highlight' | 'warning' | 'info' = 'info';
      let label = '💡 Phân tích';
      
      if (content.includes('📌') || content.toLowerCase().includes('đáng chú ý') || content.toLowerCase().includes('theo dõi')) {
        type = 'warning';
        label = '📌 Điểm đáng theo dõi';
        content = content.replace('📌', '').trim();
      } else if (content.match(/^\d{4}:/)) {
        const year = content.match(/^(\d{4}):/)?.[1];
        type = 'highlight';
        label = `📊 Hoạt động ${year}`;
        content = content.replace(/^\d{4}:/, '').trim();
      }
      
      return { type, label, content };
    });
};

const parsedRows = parseOthers(others);
---

<div class="business-model-component">
  <!-- 1. Value Chain Flow -->
  <div class="bm-section">
    <h3 class="section-subtitle">Chuỗi Giá Trị Doanh Nghiệp (Value Chain)</h3>
    <ValueChainDiagram inputs={inputs} production={production} outputs={outputs} />
  </div>

  <!-- 2. Financial Structures -->
  <div class="bm-section">
    <h3 class="section-subtitle">Cơ Cấu Doanh Thu & Lợi Nhuận</h3>
    <div class="financial-structures">
      <!-- Revenue Card -->
      <div class="structure-card">
        <h4 class="card-subtitle">Cơ cấu Doanh thu (Revenue %)</h4>
        <div class="bar-chart-container">
          {revenueStruct.map(item => (
            <div class="chart-row">
              <div class="label-col" title={item.item}>{item.item}</div>
              <div class="bar-col">
                <div class="bar bg-blue" style={`width: ${item.value}%`}></div>
              </div>
              <div class="value-col">{item.value}%</div>
            </div>
          ))}
        </div>
      </div>

      <!-- Profit Card -->
      <div class="structure-card">
        <h4 class="card-subtitle">Cơ cấu Lợi nhuận (Profit %)</h4>
        <div class="bar-chart-container">
          {profitStruct.map(item => (
            <div class="chart-row">
              <div class="label-col" title={item.item}>{item.item}</div>
              <div class="bar-col">
                <div class="bar bg-emerald" style={`width: ${item.value}%`}></div>
              </div>
              <div class="value-col">{item.value}%</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- 3. Business Analysis (Real Data Table) -->
  <div class="bm-section">
    <h3 class="section-subtitle">Phân Tích Chi Tiết Hoạt Động</h3>
    
    {parsedRows.length > 0 ? (
      <div class="others-table-container">
        <table class="others-table">
          <thead>
            <tr>
              <th class="col-label">Chủ đề phân tích</th>
              <th class="col-content">Nội dung chi tiết thực tế từ báo cáo</th>
            </tr>
          </thead>
          <tbody>
            {parsedRows.map((row) => (
              <tr class={`row-${row.type}`}>
                <td class="cell-label">
                  <span class={`type-badge badge-${row.type}`}>{row.label}</span>
                </td>
                <td class="cell-content">{row.content}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    ) : (
      <div class="empty-state-card">
        <div class="empty-icon">💡</div>
        <p class="empty-text">Dữ liệu phân tích hoạt động chi tiết đang được cập nhật và số hóa bằng AI...</p>
      </div>
    )}
  </div>
</div>

<style>
  .business-model-component {
    display: flex;
    flex-direction: column;
    gap: 3.5rem;
  }

  .bm-section {
    display: flex;
    flex-direction: column;
  }

  .section-subtitle {
    font-size: 1.25rem;
    font-weight: 800;
    margin-bottom: 1.5rem;
    border-left: 4px solid var(--accent-primary);
    padding-left: 0.75rem;
    font-family: var(--font-display);
    color: var(--text-primary);
  }

  /* Financial Structures bar charts */
  .financial-structures {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 768px) {
    .financial-structures {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .structure-card {
    background: var(--bg-secondary);
    border: 1px solid var(--border-color);
    border-radius: 20px;
    padding: 1.75rem;
    box-shadow: var(--shadow-sm);
    transition: border-color 0.2s ease;
  }

  .structure-card:hover {
    border-color: var(--accent-primary);
  }

  .card-subtitle {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 1.25rem;
    color: var(--text-secondary);
  }

  .bar-chart-container {
    display: flex;
    flex-direction: column;
    gap: 1.15rem;
  }

  .chart-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-size: 0.85rem;
    font-weight: 600;
  }

  .label-col {
    width: 150px;
    text-align: right;
    color: var(--text-secondary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .bar-col {
    flex-grow: 1;
    height: 10px;
    background: var(--bg-tertiary);
    border-radius: 9999px;
    overflow: hidden;
  }

  .bar {
    height: 100%;
    border-radius: 9999px;
    transition: width 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .bg-blue { background: var(--accent-gradient); }
  .bg-emerald { background: linear-gradient(135deg, #34d399 0%, #10b981 100%); }

  .value-col {
    width: 45px;
    text-align: left;
    font-weight: 800;
    color: var(--text-primary);
  }

  /* Others Data Table */
  .others-table-container {
    width: 100%;
    overflow-x: auto;
    border: 1px solid var(--border-color);
    border-radius: 16px;
    background: var(--bg-secondary);
    box-shadow: var(--shadow-sm);
  }

  .others-table {
    width: 100%;
    border-collapse: collapse;
    text-align: left;
    font-size: 0.9rem;
  }

  .others-table th {
    background: var(--bg-tertiary);
    color: var(--text-secondary);
    font-weight: 700;
    padding: 1rem 1.25rem;
    border-bottom: 1px solid var(--border-color);
    font-family: var(--font-display);
  }

  .col-label {
    width: 220px;
  }

  .others-table td {
    padding: 1.25rem;
    border-bottom: 1px solid var(--border-color);
    vertical-align: top;
    line-height: 1.6;
  }

  .others-table tr:last-child td {
    border-bottom: none;
  }

  .cell-label {
    font-weight: 700;
    white-space: nowrap;
  }

  .cell-content {
    color: var(--text-primary);
  }

  /* Row Highlights & Badges */
  .row-highlight {
    background: rgba(59, 130, 246, 0.02);
  }

  .row-warning {
    background: rgba(245, 158, 11, 0.02);
  }

  .row-info {
    background: transparent;
  }

  .type-badge {
    display: inline-flex;
    align-items: center;
    font-size: 0.75rem;
    font-weight: 800;
    padding: 0.35rem 0.75rem;
    border-radius: 9999px;
    letter-spacing: 0.02em;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
  }

  .badge-highlight {
    background: rgba(59, 130, 246, 0.1);
    color: #2563eb;
    border: 1px solid rgba(59, 130, 246, 0.2);
  }

  :global(.dark) .badge-highlight {
    background: rgba(59, 130, 246, 0.2);
    color: #60a5fa;
    border-color: rgba(59, 130, 246, 0.3);
  }

  .badge-warning {
    background: rgba(245, 158, 11, 0.1);
    color: #d97706;
    border: 1px solid rgba(245, 158, 11, 0.2);
  }

  :global(.dark) .badge-warning {
    background: rgba(245, 158, 11, 0.2);
    color: #fbbf24;
    border-color: rgba(245, 158, 11, 0.3);
  }

  .badge-info {
    background: rgba(107, 114, 128, 0.1);
    color: var(--text-secondary);
    border: 1px solid var(--border-color);
  }

  /* Empty State Card */
  .empty-state-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 3rem 2rem;
    background: var(--bg-secondary);
    border: 1px dashed var(--border-color);
    border-radius: 16px;
    text-align: center;
  }

  .empty-icon {
    font-size: 2rem;
    margin-bottom: 1rem;
    opacity: 0.7;
  }

  .empty-text {
    font-size: 0.9rem;
    color: var(--text-secondary);
    max-width: 400px;
    margin: 0;
  }
</style>
