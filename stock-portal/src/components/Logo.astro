---
interface Props {
  className?: string;
  size?: 'sm' | 'md' | 'lg';
  showText?: boolean;
}

const { className = '', size = 'md', showText = false } = Astro.props;

const dimensions = {
  sm: 'h-6 w-auto',
  md: 'h-8 w-auto',
  lg: 'h-10 w-auto',
};

const textSizes = {
  sm: 'text-sm font-semibold tracking-wider',
  md: 'text-lg font-bold tracking-wider',
  lg: 'text-2xl font-extrabold tracking-widest',
};
---

<a href="/" class={`flex items-center gap-2.5 group transition-opacity hover:opacity-90 ${className}`}>
  <img 
    src="/logo.png" 
    alt="Logo Lúa Hóa" 
    class={`${dimensions[size]} transition-transform duration-300 group-hover:scale-105`}
    loading="eager"
  />
  {showText && (
    <span class={`font-display bg-gradient-to-r from-primary to-emerald-500 bg-clip-text text-transparent ${textSizes[size]}`}>
      LÚA HÓA
    </span>
  )}
</a>
