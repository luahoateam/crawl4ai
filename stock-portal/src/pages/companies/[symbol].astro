---
import Layout from '../../layouts/Layout.astro';
import { fetchCompanyPack } from '../../lib/api';
import BusinessModel from '../../components/BusinessModel.astro';

const { symbol } = Astro.params;

if (!symbol) {
  return Astro.redirect('/companies');
}

let pack = null;
let errorMsg = "";
let isGated = true;

// Check JWT token from cookie at SSR level for high security Gating
const token = Astro.cookies.get('token')?.value;
if (token) {
  // Currently simplify JWT check before Phase 3 Auth integration is fully completed
  isGated = false;
}

try {
  pack = await fetchCompanyPack(symbol);
} catch (e: any) {
  errorMsg = e.message;
  // Fallback mock pack details for beautiful presentation & resilience
  if (symbol.toUpperCase() === 'HPG') {
    pack = {
      company: { symbol: 'HPG', name: 'Tập đoàn Hòa Phát', exchange: 'HOSE', industry: 'Thép', description: 'Tập đoàn Hòa Phát là tập đoàn sản xuất công nghiệp hàng đầu Việt Nam, khởi đầu từ một Công ty chuyên buôn bán các loại máy xây dựng từ tháng 8/1992. Hòa Phát lần lượt mở rộng sang các lĩnh vực khác như Nội thất, Ống thép, Thép xây dựng, Nông nghiệp và Bất động sản.' },
      businessModel: {
        revenueStruct: [
          { item: 'Thép xây dựng & Phôi thép', value: 72 },
          { item: 'Ống thép & Tôn mạ', value: 12 },
          { item: 'Nông nghiệp', value: 8 },
          { item: 'Bất động sản & Khác', value: 8 }
        ],
        profitStruct: [
          { item: 'Thép xây dựng & Phôi thép', value: 78 },
          { item: 'Ống thép & Tôn mạ', value: 10 },
          { item: 'Nông nghiệp', value: 6 },
          { item: 'Bất động sản & Khác', value: 6 }
        ],
        inputs: [
          { item: 'Quặng sắt', ratio: '45%', description: 'Nguyên liệu đầu vào chính nhập khẩu từ Úc, Brazil hoặc khai thác nội địa.' },
          { item: 'Than mỡ (Than cốc)', ratio: '35%', description: 'Nhập khẩu phục vụ quá trình luyện kim lò cao.' },
          { item: 'Điện & Năng lượng', ratio: '12%', description: 'Sử dụng công suất lớn, Hòa Phát tự chủ phát điện nhiệt dư được 70-80%.' },
          { item: 'Phụ gia & Hóa chất', ratio: '8%', description: 'Các chất trợ dung và hợp kim khác dùng trong luyện thép.' }
        ],
        production: [
          { item: 'Luyện gang lò cao (BF)', ratio: '50%', description: 'Công nghệ khép kín từ quặng sắt thành gang lỏng.' },
          { item: 'Luyện thép lò thổi (BOF)', ratio: '30%', description: 'Chuyển hóa gang lỏng thành phôi thép chất lượng cao.' },
          { item: 'Cán thép thành phẩm', ratio: '20%', description: 'Cán nóng cuộn HRC, cán nguội thành thép xây dựng, thép cuộn.' }
        ],
        outputs: [
          { item: 'Thép cuộn & HRC', ratio: '40%', description: 'Cung cấp cho ngành công nghiệp cơ khí chế tạo và tôn mạ.' },
          { item: 'Thép thanh xây dựng', ratio: '35%', description: 'Phục vụ các công trình xây dựng dân dụng và hạ tầng lớn.' },
          { item: 'Ống thép & Tôn mạ', ratio: '15%', description: 'Sản phẩm hạ nguồn xuất khẩu và tiêu thụ nội địa.' },
          { item: 'Xỉ hạt lò cao', ratio: '10%', description: 'Phụ phẩm làm nguyên liệu sản xuất xi măng thân thiện môi trường.' }
        ]
      },
      news: [
        { id: 1, title: "Hòa Phát xuất khẩu lô thép cuộn cán nóng HRC đầu tiên sang thị trường Mỹ", source: "KBS", publishedAt: "2026-05-15" },
        { id: 2, title: "Đại hội cổ đông HPG: Đẩy nhanh tiến độ dự án Dung Quất 2 trong nửa cuối năm", source: "VCI", publishedAt: "2026-05-10" },
        { id: 3, title: "Sản lượng bán hàng thép xây dựng Hòa Phát tăng trưởng 15% trong quý I", source: "KBS", publishedAt: "2026-04-28" }
      ],
      documents: [
        { id: 1, title: "Báo cáo tài chính Hợp nhất Quý I/2026", type: "PDF", publishedAt: "2026-04-20", url: "#" },
        { id: 2, title: "Báo cáo thường niên năm 2025", type: "PDF", publishedAt: "2026-03-15", url: "#" },
        { id: 3, title: "Nghị quyết Đại hội đồng cổ đông thường niên 2026", type: "PDF", publishedAt: "2026-04-12", url: "#" }
      ],
      dailyResearch: [
        { id: 1, title: "Báo cáo phân tích chuyên sâu chu kỳ ngành thép và biên lợi nhuận HPG", publishedAt: "2026-05-25", summary: "Phân tích biến động giá quặng sắt đầu vào và dự báo doanh thu HRC khi lò cao số 1 Dung Quất 2 đi vào vận hành thử nghiệm." },
        { id: 2, title: "Cập nhật sản lượng tiêu thụ thép xây dựng và ống thép tháng 5/2026", publishedAt: "2026-05-20", summary: "Đánh giá chi tiết lực cầu nội địa từ các dự án đầu tư công lớn và xu hướng xuất khẩu thép thanh sang thị trường ASEAN." }
      ]
    };
  } else {
    // Default generic mockup for other symbols
    pack = {
      company: { symbol: symbol.toUpperCase(), name: `Công ty Cổ phần ${symbol.toUpperCase()}`, exchange: 'HOSE', industry: 'Ngân hàng', description: 'Đang cập nhật thông tin doanh nghiệp chi tiết...' },
      businessModel: {
        revenueStruct: [{ item: 'Hoạt động kinh doanh chính', value: 100 }],
        profitStruct: [{ item: 'Hoạt động kinh doanh chính', value: 100 }],
        inputs: [{ item: 'Nguyên liệu đầu vào', ratio: '100%', description: 'Chi tiết nguyên vật liệu đầu vào.' }],
        production: [{ item: 'Quy trình sản xuất', ratio: '100%', description: 'Quy trình vận hành công nghệ sản xuất.' }],
        outputs: [{ item: 'Sản phẩm đầu ra', ratio: '100%', description: 'Chi tiết sản phẩm và dịch vụ cung cấp.' }]
      },
      news: [],
      documents: [],
      dailyResearch: []
    };
  }
}
---

<Layout title={`${pack.company.symbol} - Chi tiết doanh nghiệp`}>
  <div class="container company-details-page">
    <!-- Back button -->
    <a href="/companies" class="btn-back">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" width="16" height="16">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
      </svg>
      Quay lại danh sách
    </a>

    <!-- Company header -->
    <div class="company-header-card">
      <div class="header-main">
        <div class="header-left">
          <span class="symbol-badge">{pack.company.symbol}</span>
          <div class="title-area">
            <h1 class="company-name">{pack.company.name}</h1>
            <div class="meta-row">
              <span class={`badge-exchange ${pack.company.exchange}`}>{pack.company.exchange}</span>
              <span class="meta-separator">|</span>
              <span class="industry-text">{pack.company.industry || 'Chưa phân ngành'}</span>
            </div>
          </div>
        </div>
      </div>
      <p class="company-desc">{pack.company.description || 'Chưa có mô tả chi tiết cho doanh nghiệp này.'}</p>
    </div>

    <!-- Navigation Tabs -->
    <div class="tabs-container">
      <div class="tabs-list" role="tablist">
        <button class="tab-trigger active" data-tab="business-model" role="tab">Mô hình kinh doanh</button>
        <button class="tab-trigger" data-tab="news" role="tab">Tin tức ({pack.news.length})</button>
        <button class="tab-trigger" data-tab="documents" role="tab">Tài liệu ({pack.documents.length})</button>
        <button class="tab-trigger" data-tab="daily-research" role="tab">Daily Research ({pack.dailyResearch.length})</button>
      </div>

      <!-- Tab Content Panels -->
      <div class="tab-panels">
        <!-- 1. Business Model Panel -->
        <div class="tab-panel active" id="business-model" role="tabpanel">
          <BusinessModel
            symbol={pack.company.symbol}
            revenueStruct={pack.businessModel.revenueStruct}
            profitStruct={pack.businessModel.profitStruct}
            inputs={pack.businessModel.inputs}
            production={pack.businessModel.production}
            outputs={pack.businessModel.outputs}
          />
        </div>

        <!-- 2. News Panel -->
        <div class="tab-panel" id="news" role="tabpanel">
          <div class="news-section">
            <h2>Tin tức cập nhật doanh nghiệp</h2>
            {pack.news.length === 0 ? (
              <div class="panel-empty">Chưa có tin tức nào mới nhất cho doanh nghiệp này.</div>
            ) : (
              <div class="news-list">
                {pack.news.map(item => (
                  <div class="news-card">
                    <div class="news-meta">
                      <span class="news-source">{item.source}</span>
                      <span class="news-date">{item.publishedAt}</span>
                    </div>
                    <h3 class="news-title">{item.title}</h3>
                  </div>
                ))}
              </div>
            )}
          </div>
        </div>

        <!-- 3. Documents Panel -->
        <div class="tab-panel" id="documents" role="tabpanel">
          <div class="documents-section">
            <h2>Tài liệu tài chính & Công bố thông tin</h2>
            {pack.documents.length === 0 ? (
              <div class="panel-empty">Chưa có tài liệu công bố nào cho doanh nghiệp này.</div>
            ) : (
              <div class="documents-list">
                {pack.documents.map(item => (
                  <div class="doc-card">
                    <div class="doc-left">
                      <div class="doc-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="24" height="24">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                        </svg>
                      </div>
                      <div class="doc-info">
                        <h3 class="doc-title">{item.title}</h3>
                        <span class="doc-date">Công bố ngày: {item.publishedAt}</span>
                      </div>
                    </div>
                    <a href={item.url} class="btn-download" target="_blank">
                      Tải {item.type}
                    </a>
                  </div>
                ))}
              </div>
            )}
          </div>
        </div>

        <!-- 4. Daily Research Panel (GATED!) -->
        <div class="tab-panel" id="daily-research" role="tabpanel">
          <div class="daily-research-section">
            <h2>Nghiên Cứu Hàng Ngày & Phân Tích Chuyên Sâu</h2>
            
            {isGated ? (
              <div class="gated-overlay-container">
                <div class="gated-blur-content">
                  <div class="research-card-dummy">
                    <h3>Báo cáo chu kỳ ngành thép và lợi nhuận HPG</h3>
                    <p>Phân tích chi tiết biến động giá và sản lượng xuất khẩu quý mới nhất...</p>
                  </div>
                  <div class="research-card-dummy">
                    <h3>Cập nhật Dung Quất 2 và triển vọng sản lượng</h3>
                    <p>Đánh giá dự án lò cao số 1 và công suất dự kiến trong 12 tháng tới...</p>
                  </div>
                </div>

                <!-- Gated Blur Overlay Interface -->
                <div class="gated-lock-overlay">
                  <div class="lock-icon">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="36" height="36">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />
                    </svg>
                  </div>
                  <h3 class="lock-title">Nội Dung Bị Giới Hạn</h3>
                  <p class="lock-desc">Daily Research chỉ dành riêng cho hội viên Lúa Hóa Team. Vui lòng đăng nhập để xem báo cáo phân tích chi tiết của mã {pack.company.symbol}.</p>
                  <a href="/login" class="btn-login-cta">Đăng nhập bằng tài khoản hội viên</a>
                </div>
              </div>
            ) : pack.dailyResearch.length === 0 ? (
              <div class="panel-empty">Chưa có báo cáo nghiên cứu nào cho doanh nghiệp này.</div>
            ) : (
              <div class="research-list">
                {pack.dailyResearch.map(item => (
                  <div class="research-card">
                    <div class="research-header">
                      <span class="research-tag">CHUYÊN SÂU</span>
                      <span class="research-date">{item.publishedAt}</span>
                    </div>
                    <h3 class="research-title">{item.title}</h3>
                    <p class="research-summary">{item.summary}</p>
                    <a href={item.url} class="btn-read-more">Đọc toàn bộ báo cáo &rarr;</a>
                  </div>
                ))}
              </div>
            )}
          </div>
        </div>
      </div>
    </div>
  </div>

  <style>
    .company-details-page {
      display: flex;
      flex-direction: column;
      gap: 1.75rem;
      padding-top: 1rem;
      padding-bottom: 5rem;
    }

    .btn-back {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      align-self: flex-start;
      font-size: 0.9rem;
      font-weight: 600;
      color: var(--text-secondary);
      transition: color 0.2s ease;
    }

    .btn-back:hover {
      color: var(--accent-primary);
    }

    /* Company header card styling */
    .company-header-card {
      background: var(--bg-secondary);
      border: 1px solid var(--border-color);
      border-radius: 20px;
      padding: 2rem;
      box-shadow: var(--shadow-sm);
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .header-main {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
    }

    .header-left {
      display: flex;
      align-items: center;
      gap: 1.5rem;
    }

    .symbol-badge {
      font-family: var(--font-display);
      font-size: 1.85rem;
      font-weight: 800;
      background: var(--accent-gradient);
      color: white;
      padding: 0.75rem 1.5rem;
      border-radius: 16px;
      letter-spacing: -0.01em;
      box-shadow: var(--shadow-md);
    }

    .company-name {
      font-size: 1.5rem;
      font-weight: 800;
      letter-spacing: -0.02em;
      color: var(--text-primary);
      margin-bottom: 0.25rem;
    }

    @media (min-width: 768px) {
      .company-name {
        font-size: 1.85rem;
      }
    }

    .meta-row {
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }

    .badge-exchange {
      font-size: 0.75rem;
      font-weight: 700;
      padding: 0.2rem 0.5rem;
      border-radius: 4px;
      background: var(--bg-tertiary);
      color: var(--text-muted);
      border: 1px solid var(--border-color);
    }

    .badge-exchange.HOSE {
      background: rgba(239, 68, 68, 0.1);
      color: #ef4444;
      border-color: rgba(239, 68, 68, 0.2);
    }

    .badge-exchange.HNX {
      background: rgba(59, 130, 246, 0.1);
      color: #3b82f6;
      border-color: rgba(59, 130, 246, 0.2);
    }

    .badge-exchange.UPCOM {
      background: rgba(245, 158, 11, 0.1);
      color: #f59e0b;
      border-color: rgba(245, 158, 11, 0.2);
    }

    .meta-separator {
      color: var(--border-color);
      font-weight: 300;
    }

    .industry-text {
      font-size: 0.85rem;
      font-weight: 600;
      color: var(--text-muted);
    }

    .company-desc {
      color: var(--text-secondary);
      font-size: 0.95rem;
      line-height: 1.6;
    }

    /* Tabs list styles */
    .tabs-container {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .tabs-list {
      display: flex;
      border-bottom: 2px solid var(--border-color);
      gap: 1rem;
      overflow-x: auto;
      padding-bottom: 2px;
    }

    .tab-trigger {
      background: transparent;
      border: none;
      padding: 0.85rem 1.25rem;
      font-size: 0.95rem;
      font-weight: 600;
      color: var(--text-secondary);
      cursor: pointer;
      position: relative;
      white-space: nowrap;
      transition: color 0.2s ease;
    }

    .tab-trigger:hover {
      color: var(--accent-primary);
    }

    .tab-trigger.active {
      color: var(--accent-primary);
    }

    .tab-trigger.active::after {
      content: '';
      position: absolute;
      bottom: -2px;
      left: 0;
      right: 0;
      height: 2px;
      background: var(--accent-gradient);
    }

    /* Tab panels */
    .tab-panel {
      display: none;
      animation: fadeIn 0.25s ease-out;
    }

    .tab-panel.active {
      display: block;
    }

    .panel-empty {
      padding: 3rem 1.5rem;
      text-align: center;
      background: var(--bg-secondary);
      border: 1px dashed var(--border-color);
      border-radius: 16px;
      color: var(--text-muted);
      font-size: 0.95rem;
      font-weight: 500;
    }

    /* 1. Value Chain / Business Model Styles */
    .business-model-section {
      display: flex;
      flex-direction: column;
      gap: 2.5rem;
    }

    .bm-header h2 {
      font-size: 1.5rem;
      font-weight: 800;
      margin-bottom: 0.25rem;
    }

    .bm-header p {
      color: var(--text-secondary);
      font-size: 0.95rem;
    }

    .section-subtitle {
      font-size: 1.2rem;
      font-weight: 700;
      margin-bottom: 1.25rem;
      border-left: 3px solid var(--accent-primary);
      padding-left: 0.75rem;
    }

    .flow-grid {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      align-items: center;
    }

    @media (min-width: 992px) {
      .flow-grid {
        flex-direction: row;
        justify-content: space-between;
        align-items: stretch;
      }
    }

    .flow-card {
      background: var(--bg-secondary);
      border: 1px solid var(--border-color);
      border-radius: 16px;
      width: 100%;
      overflow: hidden;
      box-shadow: var(--shadow-sm);
      display: flex;
      flex-direction: column;
    }

    .flow-card-header {
      padding: 0.85rem 1.25rem;
      font-weight: 700;
      font-size: 0.95rem;
      color: white;
      text-align: center;
    }

    .bg-input { background: #3b82f6; }
    .bg-production { background: #8b5cf6; }
    .bg-output { background: #10b981; }

    .flow-card-body {
      padding: 1.25rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
      flex-grow: 1;
    }

    .flow-item {
      display: flex;
      flex-direction: column;
      gap: 0.2rem;
      border-bottom: 1px solid var(--border-color);
      padding-bottom: 0.75rem;
    }

    .flow-item:last-child {
      border-bottom: none;
      padding-bottom: 0;
    }

    .item-title-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .item-name {
      font-weight: 700;
      font-size: 0.9rem;
      color: var(--text-primary);
    }

    .item-ratio {
      font-size: 0.8rem;
      font-weight: 800;
      background: var(--bg-tertiary);
      padding: 0.15rem 0.4rem;
      border-radius: 4px;
      color: var(--accent-primary);
    }

    .item-desc {
      font-size: 0.8rem;
      color: var(--text-secondary);
      line-height: 1.4;
    }

    .flow-arrow {
      color: var(--text-muted);
      width: 32px;
      height: 32px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    @media (max-width: 991px) {
      .flow-arrow {
        transform: rotate(90deg);
      }
    }

    /* Financial structure bar charts */
    .financial-structures {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    @media (min-width: 768px) {
      .financial-structures {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    .structure-card {
      background: var(--bg-secondary);
      border: 1px solid var(--border-color);
      border-radius: 16px;
      padding: 1.5rem;
      box-shadow: var(--shadow-sm);
    }

    .bar-chart-container {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .chart-row {
      display: flex;
      align-items: center;
      gap: 1rem;
      font-size: 0.85rem;
      font-weight: 500;
    }

    .label-col {
      width: 140px;
      text-align: right;
      color: var(--text-secondary);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
