---
import Layout from '../../layouts/Layout.astro';
import { fetchCompanyPack } from '../../lib/api';
import BusinessModel from '../../components/BusinessModel.astro';

const { symbol } = Astro.params;

if (!symbol) {
  return Astro.redirect('/companies');
}

let pack = null;
let errorMsg = "";
let isGated = true;

// Check JWT token from cookie at SSR level for high security Gating
const token = Astro.cookies.get('token')?.value;
if (token) {
  isGated = false;
}

try {
  pack = await fetchCompanyPack(symbol);
} catch (e: any) {
  errorMsg = e.message;
  // Fallback mock pack details for beautiful presentation & resilience
  if (symbol.toUpperCase() === 'HPG') {
    pack = {
      company: { symbol: 'HPG', name: 'Tập đoàn Hòa Phát', exchange: 'HOSE', industry: 'Thép', description: 'Tập đoàn Hòa Phát là tập đoàn sản xuất công nghiệp hàng đầu Việt Nam, khởi đầu từ một Công ty chuyên buôn bán các loại máy xây dựng từ tháng 8/1992. Hòa Phát lần lượt mở rộng sang các lĩnh vực khác như Nội thất, Ống thép, Thép xây dựng, Nông nghiệp và Bất động sản.' },
      businessModel: {
        revenueStruct: [
          { item: 'Thép xây dựng & Phôi thép', value: 72 },
          { item: 'Ống thép & Tôn mạ', value: 12 },
          { item: 'Nông nghiệp', value: 8 },
          { item: 'Bất động sản & Khác', value: 8 }
        ],
        profitStruct: [
          { item: 'Thép xây dựng & Phôi thép', value: 78 },
          { item: 'Ống thép & Tôn mạ', value: 10 },
          { item: 'Nông nghiệp', value: 6 },
          { item: 'Bất động sản & Khác', value: 6 }
        ],
        inputs: [
          { item: 'Quặng sắt', ratio: '45%', description: 'Nguyên liệu đầu vào chính nhập khẩu từ Úc, Brazil hoặc khai thác nội địa.' },
          { item: 'Than mỡ (Than cốc)', ratio: '35%', description: 'Nhập khẩu phục vụ quá trình luyện kim lò cao.' },
          { item: 'Điện & Năng lượng', ratio: '12%', description: 'Sử dụng công suất lớn, Hòa Phát tự chủ phát điện nhiệt dư được 70-80%.' },
          { item: 'Phụ gia & Hóa chất', ratio: '8%', description: 'Các chất trợ dung và hợp kim khác dùng trong luyện thép.' }
        ],
        production: [
          { item: 'Luyện gang lò cao (BF)', ratio: '50%', description: 'Công nghệ khép kín từ quặng sắt thành gang lỏng.' },
          { item: 'Luyện thép lò thổi (BOF)', ratio: '30%', description: 'Chuyển hóa gang lỏng thành phôi thép chất lượng cao.' },
          { item: 'Cán thép thành phẩm', ratio: '20%', description: 'Cán nóng cuộn HRC, cán nguội thành thép xây dựng, thép cuộn.' }
        ],
        outputs: [
          { item: 'Thép cuộn & HRC', ratio: '40%', description: 'Cung cấp cho ngành công nghiệp cơ khí chế tạo và tôn mạ.' },
          { item: 'Thép thanh xây dựng', ratio: '35%', description: 'Phục vụ các công trình xây dựng dân dụng và hạ tầng lớn.' },
          { item: 'Ống thép & Tôn mạ', ratio: '15%', description: 'Sản phẩm hạ nguồn xuất khẩu và tiêu thụ nội địa.' },
          { item: 'Xỉ hạt lò cao', ratio: '10%', description: 'Phụ phẩm làm nguyên liệu sản xuất xi măng thân thiện môi trường.' }
        ]
      },
      news: [
        { id: 1, title: "Hòa Phát xuất khẩu lô thép cuộn cán nóng HRC đầu tiên sang thị trường Mỹ", source: "KBS", publishedAt: "2026-05-15" },
        { id: 2, title: "Đại hội cổ đông HPG: Đẩy nhanh tiến độ dự án Dung Quất 2 trong nửa cuối năm", source: "VCI", publishedAt: "2026-05-10" },
        { id: 3, title: "Sản lượng bán hàng thép xây dựng Hòa Phát tăng trưởng 15% trong quý I", source: "KBS", publishedAt: "2026-04-28" }
      ],
      documents: [
        { id: 1, title: "Báo cáo tài chính Hợp nhất Quý I/2026", type: "PDF", publishedAt: "2026-04-20", url: "#" },
        { id: 2, title: "Báo cáo thường niên năm 2025", type: "PDF", publishedAt: "2026-03-15", url: "#" },
        { id: 3, title: "Nghị quyết Đại hội đồng cổ đông thường niên 2026", type: "PDF", publishedAt: "2026-04-12", url: "#" }
      ],
      dailyResearch: [
        { id: 1, title: "Báo cáo phân tích chuyên sâu chu kỳ ngành thép và biên lợi nhuận HPG", publishedAt: "2026-05-25", summary: "Phân tích biến động giá quặng sắt đầu vào và dự báo doanh thu HRC khi lò cao số 1 Dung Quất 2 đi vào vận hành thử nghiệm." },
        { id: 2, title: "Cập nhật sản lượng tiêu thụ thép xây dựng và ống thép tháng 5/2026", publishedAt: "2026-05-20", summary: "Đánh giá chi tiết lực cầu nội địa từ các dự án đầu tư công lớn và xu hướng xuất khẩu thép thanh sang thị trường ASEAN." }
      ]
    };
  } else {
    // Default generic mockup for other symbols
    pack = {
      company: { symbol: symbol.toUpperCase(), name: `Công ty Cổ phần ${symbol.toUpperCase()}`, exchange: 'HOSE', industry: 'Ngân hàng', description: 'Đang cập nhật thông tin doanh nghiệp chi tiết...' },
      businessModel: {
        revenueStruct: [{ item: 'Hoạt động kinh doanh chính', value: 100 }],
        profitStruct: [{ item: 'Hoạt động kinh doanh chính', value: 100 }],
        inputs: [{ item: 'Nguyên liệu đầu vào', ratio: '100%', description: 'Chi tiết nguyên vật liệu đầu vào.' }],
        production: [{ item: 'Quy trình sản xuất', ratio: '100%', description: 'Quy trình vận hành công nghệ sản xuất.' }],
        outputs: [{ item: 'Sản phẩm đầu ra', ratio: '100%', description: 'Chi tiết sản phẩm và dịch vụ cung cấp.' }]
      },
      news: [],
      documents: [],
      dailyResearch: []
    };
  }
}
---

<Layout title={`${pack.company.symbol} - Chi tiết doanh nghiệp`}>
  <div class="flex flex-col gap-6 py-2">
    <!-- Back button -->
    <a href="/companies" class="inline-flex items-center gap-2 text-sm font-semibold text-muted-foreground hover:text-foreground transition-colors min-h-[44px] self-start">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
      </svg>
      Quay lại danh sách
    </a>

    <!-- Company header -->
    <div class="bg-card border border-border rounded-2xl p-6 shadow-sm flex flex-col gap-4">
      <div class="flex flex-col sm:flex-row justify-between items-start gap-4">
        <div class="flex items-center gap-4">
          <span class="symbol-badge font-display font-extrabold text-3xl bg-gradient-to-r from-primary to-blue-600 text-white px-4 py-2 rounded-xl shadow-md tracking-tight">{pack.company.symbol}</span>
          <div>
            <h1 class="text-xl sm:text-2xl font-extrabold text-foreground tracking-tight">{pack.company.name}</h1>
            <div class="flex items-center gap-2 mt-1">
              <span class={`text-[10px] font-extrabold px-2 py-0.5 rounded border border-border ${pack.company.exchange === 'HOSE' ? 'text-rose-500 bg-rose-500/5 border-rose-500/20' : pack.company.exchange === 'HNX' ? 'text-blue-500 bg-blue-500/5 border-blue-500/20' : 'text-slate-500'}`}>{pack.company.exchange}</span>
              <span class="text-muted-foreground/40 text-xs">|</span>
              <span class="text-xs font-semibold text-muted-foreground">{pack.company.industry || 'Chưa phân ngành'}</span>
            </div>
          </div>
        </div>
      </div>
      <p class="text-sm text-muted-foreground leading-relaxed mt-2">{pack.company.description || 'Chưa có mô tả chi tiết cho doanh nghiệp này.'}</p>
      

    </div>

    <!-- Navigation Tabs -->
    <div class="flex flex-col gap-6">
      <div class="flex border-b border-border gap-2 overflow-x-auto pb-0.5" role="tablist">
        <button class="px-4 py-2.5 text-sm font-bold text-muted-foreground hover:text-foreground border-b-2 border-transparent -mb-[2px] transition-all cursor-pointer tab-trigger active" data-tab="business-model" role="tab">Mô hình kinh doanh</button>
        <button class="px-4 py-2.5 text-sm font-bold text-muted-foreground hover:text-foreground border-b-2 border-transparent -mb-[2px] transition-all cursor-pointer tab-trigger" data-tab="documents" role="tab">Báo cáo tài chính ({pack.documents.length})</button>
        <button class="px-4 py-2.5 text-sm font-bold text-muted-foreground hover:text-foreground border-b-2 border-transparent -mb-[2px] transition-all cursor-pointer tab-trigger" data-tab="daily-research" role="tab">Nghiên cứu của SSI Research ({pack.dailyResearch.length})</button>
      </div>

      <!-- Tab Content Panels -->
      <div class="relative">
        <!-- 1. Business Model Panel -->
        <div class="hidden tab-panel" id="business-model" role="tabpanel">
          <BusinessModel
            symbol={pack.company.symbol}
            revenueStruct={pack.businessModel.revenueStruct}
            profitStruct={pack.businessModel.profitStruct}
            inputs={pack.businessModel.inputs}
            production={pack.businessModel.production}
            outputs={pack.businessModel.outputs}
            others={pack.businessModel.others}
          />

          <!-- Section website chính chủ lấy từ DB news -->
          <div class="mt-8 border-t border-border pt-6">
            <h3 class="text-base font-bold text-foreground mb-4 flex items-center gap-2 font-display">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4.5 h-4.5 text-primary">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244" />
              </svg>
              Thông tin thêm từ website chính chủ của doanh nghiệp
            </h3>
            {pack.news.length === 0 ? (
              <p class="text-xs text-muted-foreground italic pl-1">Không có tin tức liên kết nào từ website chính thức.</p>
            ) : (
              <ul class="space-y-2.5 pl-1">
                {pack.news.map((item: any) => (
                  <li class="flex items-start gap-2 text-sm">
                    <span class="text-primary mt-1">•</span>
                    <div class="flex flex-col sm:flex-row sm:items-center gap-1.5">
                      <a 
                        href={item.url} 
                        target="_blank" 
                        rel="noopener noreferrer" 
                        class="text-primary hover:underline font-medium leading-relaxed"
                      >
                        {item.title}
                      </a>
                      <span class="text-[10px] bg-muted border border-border px-2 py-0.5 rounded font-semibold text-muted-foreground self-start sm:self-center whitespace-nowrap">
                        {item.source} • {new Date(item.publishedAt).toLocaleDateString('vi-VN')}
                      </span>
                    </div>
                  </li>
                ))}
              </ul>
            )}
          </div>
        </div>



        <!-- 3. Documents Panel -->
        <div class="hidden tab-panel" id="documents" role="tabpanel">
          <div class="flex flex-col gap-4">
            <h2 class="text-lg font-bold text-foreground pl-1">Báo cáo tài chính cho AI đọc</h2>
            {pack.documents.length === 0 ? (
              <div class="py-12 text-center text-muted-foreground border border-dashed border-border rounded-2xl bg-card">Chưa có báo cáo tài chính nào cho doanh nghiệp này.</div>
            ) : (
              <div class="flex flex-col gap-3">
                {pack.documents.map(item => (
                  <div class="bg-card border border-border rounded-xl p-4 flex items-center justify-between gap-4 hover:border-primary transition-all duration-200">
                    <div class="flex items-center gap-3">
                      <div class="p-2 bg-primary/10 text-primary rounded-lg">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
                        </svg>
                      </div>
                      <div class="flex flex-col gap-0.5">
                        <h3 class="text-sm font-semibold text-foreground leading-snug">{item.title}</h3>
                        <span class="text-xs text-muted-foreground">Công bố ngày: {item.publishedAt}</span>
                      </div>
                    </div>
                    <a href={item.url} class="bg-muted hover:bg-primary hover:text-primary-foreground text-foreground px-4 py-2 rounded-lg text-xs font-bold transition-all duration-200 min-h-[44px] flex items-center justify-center" target="_blank">
                      Đọc bằng AI
                    </a>
                  </div>
                ))}
              </div>
            )}
          </div>
        </div>

        <!-- 4. Daily Research Panel (GATED!) -->
        <div class="hidden tab-panel" id="daily-research" role="tabpanel">
          <div class="flex flex-col gap-4 relative">
            <h2 class="text-lg font-bold text-foreground pl-1">Nghiên cứu của SSI Research</h2>
            
            {isGated ? (
              <div class="relative rounded-2xl overflow-hidden border border-border p-4 bg-muted/20">
                <div class="filter blur-md pointer-events-none select-none flex flex-col gap-4">
                  <div class="bg-card border border-border rounded-xl p-5 flex flex-col gap-2">
                    <h3 class="text-base font-bold text-foreground font-display">Báo cáo chu kỳ ngành thép và lợi nhuận HPG</h3>
                    <p class="text-sm text-muted-foreground leading-relaxed">Phân tích chi tiết biến động giá và sản lượng xuất khẩu quý mới nhất...</p>
                  </div>
                  <div class="bg-card border border-border rounded-xl p-5 flex flex-col gap-2">
                    <h3 class="text-base font-bold text-foreground font-display">Cập nhật Dung Quất 2 và triển vọng sản lượng</h3>
                    <p class="text-sm text-muted-foreground leading-relaxed">Đánh giá dự án lò cao số 1 và công suất dự kiến trong 12 tháng tới...</p>
                  </div>
                </div>

                <!-- Gated Blur Overlay Interface -->
                <div class="gated-lock-overlay absolute inset-0 bg-slate-950/85 backdrop-blur-md flex flex-col items-center justify-center gap-3 p-6 text-center z-10">
                  <div class="w-12 h-12 bg-primary/20 text-primary rounded-full flex items-center justify-center text-xl font-bold shadow-md border border-primary/30">
                    🔒
                  </div>
                  <h3 class="lock-title text-white text-base font-bold tracking-wide">Nội Dung Bị Giới Hạn</h3>
                  <p class="text-slate-400 text-xs max-w-sm leading-relaxed px-4">Báo cáo nghiên cứu của SSI Research chỉ dành riêng cho hội viên Lúa Hóa Team. Vui lòng đăng nhập để xem báo cáo phân tích chi tiết của mã {pack.company.symbol}.</p>
                  <a href="/login" class="btn-login-cta mt-2 bg-gradient-to-r from-primary to-blue-600 text-white font-bold text-sm px-6 py-2.5 rounded-full shadow-lg hover:shadow-primary/30 hover:scale-105 transition-all duration-200 min-h-[44px] flex items-center justify-center">Đăng nhập tài khoản hội viên</a>
                </div>
              </div>
            ) : pack.dailyResearch.length === 0 ? (
              <div class="py-12 text-center text-muted-foreground border border-dashed border-border rounded-2xl bg-card">Chưa có báo cáo nghiên cứu nào cho doanh nghiệp này.</div>
            ) : (
              <div class="flex flex-col gap-4">
                {pack.dailyResearch.map(item => (
                  <div class="research-card bg-card border border-border rounded-xl p-5 flex flex-col gap-3 hover:border-primary transition-all duration-200">
                    <div class="flex justify-between items-center text-xs text-muted-foreground">
                      <span class="text-[10px] font-extrabold px-1.5 py-0.5 rounded bg-emerald-500/10 text-emerald-600 border border-emerald-500/20 uppercase tracking-wider">CHUYÊN SÂU</span>
                      <span>{item.publishedAt}</span>
                    </div>
                    <h3 class="text-base font-bold text-foreground font-display">{item.title}</h3>
                    <div class="text-sm text-muted-foreground leading-relaxed whitespace-pre-line">
                      {item.ssiReview || item.summary}
                    </div>
                  </div>
                ))}
              </div>
            )}
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  /* Active states for triggers */
  .tab-trigger.active {
    color: hsl(var(--primary)) !important;
    border-bottom-color: hsl(var(--primary)) !important;
  }
  /* Active panel display */
  .tab-panel.active {
    display: block !important;
  }
</style>

<!-- Client-side Tab Switcher Script -->
<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const tabTriggers = document.querySelectorAll('.tab-trigger');
    const tabPanels = document.querySelectorAll('.tab-panel');

    const switchTab = (targetTabId) => {
      tabTriggers.forEach(t => {
        if (t.getAttribute('data-tab') === targetTabId) {
          t.classList.add('active');
        } else {
          t.classList.remove('active');
        }
      });
      tabPanels.forEach(p => {
        if (p.getAttribute('id') === targetTabId) {
          p.classList.add('active');
        } else {
          p.classList.remove('active');
        }
      });
    };

    tabTriggers.forEach(trigger => {
      trigger.addEventListener('click', () => {
        const targetTabId = trigger.getAttribute('data-tab');
        switchTab(targetTabId);
        // Persist tab selection in hash if needed
        window.location.hash = targetTabId;
      });
    });

    // Handle initial hash routing
    const hash = window.location.hash ? window.location.hash.substring(1) : 'business-model';
    const activePanel = document.getElementById(hash);
    if (activePanel) {
      switchTab(hash);
    } else {
      switchTab('business-model');
    }
  });
</script>
