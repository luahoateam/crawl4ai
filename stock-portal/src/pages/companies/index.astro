---
import Layout from '../../layouts/Layout.astro';
import { fetchCompanies } from '../../lib/api';

let companies = [];
let errorMsg = "";

try {
  companies = await fetchCompanies();
} catch (e: any) {
  errorMsg = e.message;
  // Premium fallback mock data
  companies = [
    { symbol: 'HPG', name: 'Tập đoàn Hòa Phát', exchange: 'HOSE', industry: 'Thép' },
    { symbol: 'HSG', name: 'Tập đoàn Hoa Sen', exchange: 'HOSE', industry: 'Thép' },
    { symbol: 'NKG', name: 'Thép Nam Kim', exchange: 'HOSE', industry: 'Thép' },
    { symbol: 'VCB', name: 'Ngân hàng Vietcombank', exchange: 'HOSE', industry: 'Ngân hàng' },
    { symbol: 'ACB', name: 'Ngân hàng ACB', exchange: 'HNX', industry: 'Ngân hàng' },
    { symbol: 'BID', name: 'Ngân hàng BIDV', exchange: 'HOSE', industry: 'Ngân hàng' },
    { symbol: 'CTG', name: 'VietinBank', exchange: 'HOSE', industry: 'Ngân hàng' },
    { symbol: 'MBB', name: 'Ngân hàng Quân Đội', exchange: 'HOSE', industry: 'Ngân hàng' },
    { symbol: 'VND', name: 'Chứng khoán VNDirect', exchange: 'HOSE', industry: 'Chứng khoán' },
    { symbol: 'SSI', name: 'Chứng khoán SSI', exchange: 'HOSE', industry: 'Chứng khoán' },
    { symbol: 'VCI', name: 'Chứng khoán Vietcap', exchange: 'HOSE', industry: 'Chứng khoán' },
    { symbol: 'FPT', name: 'Tập đoàn FPT', exchange: 'HOSE', industry: 'Công nghệ' },
    { symbol: 'MWG', name: 'Thế Giới Di Động', exchange: 'HOSE', industry: 'Bán lẻ' },
    { symbol: 'PNJ', name: 'Vàng bạc Phú Nhuận', exchange: 'HOSE', industry: 'Bán lẻ' },
    { symbol: 'VNM', name: 'Vinamilk', exchange: 'HOSE', industry: 'Thực phẩm' },
    { symbol: 'VIC', name: 'Tập đoàn Vingroup', exchange: 'HOSE', industry: 'Bất động sản' },
    { symbol: 'VHM', name: 'Vinhomes', exchange: 'HOSE', industry: 'Bất động sản' }
  ];
}

// Generate unique list of industries for filtering
const industries = [...new Set(companies.map(c => c.industry).filter(Boolean))].sort();
---

<Layout title="Danh sách Doanh nghiệp - Stock Portal">
  <div class="container companies-page">
    <div class="page-header">
      <h1 class="page-title">Danh sách Doanh nghiệp niêm yết</h1>
      <p class="page-desc">Tra cứu nhanh mô hình kinh doanh và chuỗi giá trị của các doanh nghiệp trên thị trường.</p>
    </div>

    <!-- Filter Bar -->
    <div class="filter-bar">
      <!-- Search Input -->
      <div class="search-field">
        <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <input type="text" id="grid-search" placeholder="Tìm kiếm mã cổ phiếu hoặc tên doanh nghiệp..." autocomplete="off" />
      </div>

      <div class="select-fields">
        <!-- Exchange Filter -->
        <div class="select-wrapper">
          <select id="filter-exchange" aria-label="Lọc theo Sàn giao dịch">
            <option value="all">Tất cả các Sàn</option>
            <option value="HOSE">Sàn HOSE</option>
            <option value="HNX">Sàn HNX</option>
            <option value="UPCOM">Sàn UPCOM</option>
          </select>
        </div>

        <!-- Industry Filter -->
        <div class="select-wrapper">
          <select id="filter-industry" aria-label="Lọc theo Ngành nghề">
            <option value="all">Tất cả các Ngành</option>
            {industries.map(ind => (
              <option value={ind}>{ind}</option>
            ))}
          </select>
        </div>
      </div>
    </div>

    <!-- Active filters display -->
    <div class="results-meta">
      Hiện có <span id="results-count" class="count-highlight">{companies.length}</span> doanh nghiệp khớp bộ lọc
    </div>

    <!-- Error alert if API fails -->
    {errorMsg && (
      <div class="api-warning">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="20" height="20">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
        </svg>
        <span>Chế độ ngoại tuyến: Hiển thị danh sách doanh nghiệp mẫu. (Lỗi: {errorMsg})</span>
      </div>
    )}

    <!-- Company Grid -->
    <div class="companies-grid" id="companies-grid">
      {companies.map(company => (
        <a 
          href={`/companies/${company.symbol}`} 
          class="company-card" 
          data-symbol={company.symbol}
          data-name={company.name}
          data-exchange={company.exchange}
          data-industry={company.industry || ''}
        >
          <div class="card-header">
            <span class="company-symbol">{company.symbol}</span>
            <span class={`badge-exchange ${company.exchange}`}>{company.exchange}</span>
          </div>
          <h2 class="company-title">{company.name}</h2>
          <div class="card-footer">
            <span class="company-industry-tag">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="14" height="14">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
              </svg>
              {company.industry || 'Chưa phân ngành'}
            </span>
          </div>
        </a>
      ))}
    </div>

    <!-- Empty State -->
    <div class="empty-state" id="empty-state" style="display: none;">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="empty-icon">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15.182 16.318A4.486 4.486 0 0012.016 15a4.486 4.486 0 00-3.198 1.302m0-6.098a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0zm9 0a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0zM12 21a9.003 9.003 0 008.354-5.646 9.003 9.003 0 00-8.354.343M12 21a9.003 9.003 0 01-8.354-5.646 9.003 9.003 0 018.354.343M12 3a9 9 0 000 18 9 9 0 000-18z" />
      </svg>
      <h3>Không tìm thấy doanh nghiệp nào</h3>
      <p>Vui lòng thử lại với từ khóa tìm kiếm hoặc bộ lọc khác.</p>
    </div>

    <!-- Load More Button -->
    <div class="pagination-container" id="pagination-container" style="display: none;">
      <button id="load-more-btn" class="btn-load-more">Xem thêm doanh nghiệp</button>
    </div>
  </div>

  <style>
    .companies-page {
      display: flex;
      flex-direction: column;
      gap: 2rem;
      padding-top: 1rem;
      padding-bottom: 5rem;
    }

    .page-header {
      border-left: 4px solid var(--accent-primary);
      padding-left: 1rem;
    }

    .page-title {
      font-size: 2.25rem;
      font-weight: 800;
      letter-spacing: -0.025em;
      margin-bottom: 0.5rem;
    }

    .page-desc {
      color: var(--text-secondary);
      font-size: 1rem;
      max-width: 600px;
    }

    /* Filter Bar Styles */
    .filter-bar {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      background: var(--bg-secondary);
      border: 1px solid var(--border-color);
      border-radius: 16px;
      padding: 1.25rem;
      box-shadow: var(--shadow-sm);
    }

    @media (min-width: 992px) {
      .filter-bar {
        flex-direction: row;
        align-items: center;
        justify-content: space-between;
      }
    }

    .search-field {
      position: relative;
      flex-grow: 1;
      display: flex;
      align-items: center;
    }

    .search-icon {
      position: absolute;
      left: 1rem;
      width: 20px;
      height: 20px;
      color: var(--text-muted);
      pointer-events: none;
    }

    #grid-search {
      width: 100%;
      background: var(--bg-primary);
      border: 1px solid var(--border-color);
      border-radius: 9999px;
      padding: 0.75rem 1rem 0.75rem 2.75rem;
      font-size: 0.95rem;
      color: var(--text-primary);
      font-family: var(--font-sans);
      outline: none;
      transition: all 0.25s ease;
    }

    #grid-search:focus {
      border-color: var(--accent-primary);
      box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
    }

    .select-fields {
      display: flex;
      gap: 1rem;
      flex-shrink: 0;
    }

    .select-wrapper {
      position: relative;
      min-width: 160px;
    }

    .select-fields select {
      width: 100%;
      appearance: none;
      background: var(--bg-primary);
      border: 1px solid var(--border-color);
      border-radius: 9999px;
      padding: 0.75rem 2rem 0.75rem 1.25rem;
      font-size: 0.9rem;
      font-weight: 500;
      color: var(--text-primary);
      font-family: var(--font-sans);
      outline: none;
      cursor: pointer;
      transition: all 0.25s ease;
    }

    .select-fields select:focus {
      border-color: var(--accent-primary);
    }

    /* Custom select arrow styling */
    .select-wrapper::after {
      content: '';
      position: absolute;
      right: 1.15rem;
      top: 50%;
      transform: translateY(-50%);
      border: 5px solid transparent;
      border-top-color: var(--text-muted);
      pointer-events: none;
    }

    .results-meta {
      font-size: 0.9rem;
      color: var(--text-secondary);
      font-weight: 500;
    }

    .count-highlight {
      font-family: var(--font-display);
      font-weight: 800;
      color: var(--accent-primary);
      font-size: 1.1rem;
    }

    .api-warning {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      background: rgba(245, 158, 11, 0.08);
      border: 1px solid rgba(245, 158, 11, 0.25);
      border-radius: 12px;
      padding: 1rem 1.25rem;
      color: #d97706;
      font-size: 0.9rem;
      font-weight: 500;
    }

    .api-warning svg {
      flex-shrink: 0;
    }

    /* Grid Layout for Cards */
    .companies-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    @media (min-width: 576px) {
      .companies-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (min-width: 992px) {
      .companies-grid {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    /* Premium Company Card */
    .company-card {
      background: var(--bg-secondary);
      border: 1px solid var(--border-color);
      border-radius: 16px;
      padding: 1.75rem;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      gap: 1.25rem;
      box-shadow: var(--shadow-sm);
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .company-card:hover {
      transform: translateY(-4px);
      border-color: var(--accent-primary);
      box-shadow: var(--shadow-md);
    }

    .card-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .company-symbol {
      font-family: var(--font-display);
      font-size: 1.25rem;
      font-weight: 800;
      color: var(--accent-primary);
    }

    .badge-exchange {
      font-size: 0.75rem;
      font-weight: 700;
      padding: 0.2rem 0.5rem;
      border-radius: 4px;
      background: var(--bg-tertiary);
      color: var(--text-muted);
      border: 1px solid var(--border-color);
    }

    .badge-exchange.HOSE {
      background: rgba(239, 68, 68, 0.1);
      color: #ef4444;
      border-color: rgba(239, 68, 68, 0.2);
    }

    .badge-exchange.HNX {
      background: rgba(59, 130, 246, 0.1);
      color: #3b82f6;
      border-color: rgba(59, 130, 246, 0.2);
    }

    .badge-exchange.UPCOM {
      background: rgba(245, 158, 11, 0.1);
      color: #f59e0b;
      border-color: rgba(245, 158, 11, 0.2);
    }

    .company-title {
      font-size: 1.05rem;
      font-weight: 600;
      line-height: 1.4;
      color: var(--text-primary);
      height: 48px;
      overflow: hidden;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
    }

    .company-industry-tag {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      font-size: 0.75rem;
      font-weight: 600;
      color: var(--text-muted);
      background-color: var(--bg-primary);
      padding: 0.35rem 0.75rem;
      border-radius: 9999px;
      border: 1px solid var(--border-color);
    }

    /* Empty state styling */
    .empty-state {
      padding: 4rem 1.5rem;
      text-align: center;
      background: var(--bg-secondary);
      border: 1px dashed var(--border-color);
      border-radius: 16px;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1rem;
    }

    .empty-icon {
      width: 48px;
      height: 48px;
      color: var(--text-muted);
    }

    .empty-state h3 {
      font-size: 1.2rem;
      font-weight: 700;
    }

    .empty-state p {
      color: var(--text-secondary);
      font-size: 0.95rem;
      max-width: 400px;
    }

    /* Load more styles */
    .pagination-container {
      margin-top: 2rem;
      text-align: center;
    }

    .btn-load-more {
      background: var(--bg-secondary);
      color: var(--text-primary);
      border: 1px solid var(--border-color);
      padding: 0.75rem 2rem;
      font-size: 0.95rem;
      font-weight: 600;
      border-radius: 9999px;
      cursor: pointer;
      box-shadow: var(--shadow-sm);
      transition: all 0.2s ease;
    }

    .btn-load-more:hover {
      background: var(--bg-tertiary);
      border-color: var(--text-muted);
      transform: scale(1.02);
    }
  </style>

  <!-- Client-side Instant Filter script -->
  <script is:inline>
    function removeVietnameseTones(str) {
      return str
        .normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '')
        .replace(/đ/g, 'd')
        .replace(/Đ/g, 'd')
        .toLowerCase();
    }

    document.addEventListener('DOMContentLoaded', () => {
      const searchInput = document.getElementById('grid-search');
      const exchangeSelect = document.getElementById('filter-exchange');
      const industrySelect = document.getElementById('filter-industry');
      const countDisplay = document.getElementById('results-count');
      const cards = Array.from(document.querySelectorAll('.company-card'));
      const emptyState = document.getElementById('empty-state');
      const loadMoreBtn = document.getElementById('load-more-btn');
      const paginationContainer = document.getElementById('pagination-container');

      const PAGE_SIZE = 50;
      let visibleCount = PAGE_SIZE;
      let currentFilteredCards = [...cards];

      const applyFilters = () => {
        const query = searchInput.value.trim().toLowerCase();
        const normalizedQuery = removeVietnameseTones(query);
        const exchange = exchangeSelect.value;
        const industry = industrySelect.value;

        // Reset visibility
        currentFilteredCards = cards.filter(card => {
          // Exchange Match
          if (exchange !== 'all' && card.getAttribute('data-exchange') !== exchange) {
            return false;
          }

          // Industry Match
          if (industry !== 'all' && card.getAttribute('data-industry') !== industry) {
            return false;
          }

          // Search Match
          if (query) {
            const symbol = card.getAttribute('data-symbol').toLowerCase();
            const name = card.getAttribute('data-name').toLowerCase();
            const normalizedSymbol = removeVietnameseTones(symbol);
            const normalizedName = removeVietnameseTones(name);

            const matchSymbol = symbol.includes(query) || normalizedSymbol.includes(normalizedQuery);
            const matchName = name.includes(query) || normalizedName.includes(normalizedQuery);

            if (!matchSymbol && !matchName) {
              return false;
            }
          }

          return true;
        });

        // Hide all cards first
        cards.forEach(card => card.style.display = 'none');

        // Update active count
        countDisplay.textContent = currentFilteredCards.length;

        // Show empty state if no results
        if (currentFilteredCards.length === 0) {
          emptyState.style.display = 'flex';
          paginationContainer.style.display = 'none';
          return;
        } else {
          emptyState.style.display = 'none';
        }

        // Handle Pagination rendering
        visibleCount = PAGE_SIZE;
        renderPaginated();
      };

      const renderPaginated = () => {
        const toShow = currentFilteredCards.slice(0, visibleCount);
        toShow.forEach(card => card.style.display = 'flex');

        if (visibleCount < currentFilteredCards.length) {
          paginationContainer.style.display = 'block';
        } else {
          paginationContainer.style.display = 'none';
        }
      };

      // Load more click handler
      if (loadMoreBtn) {
        loadMoreBtn.addEventListener('click', () => {
          visibleCount += PAGE_SIZE;
          renderPaginated();
        });
      }

      // Event listeners
      searchInput.addEventListener('input', applyFilters);
      exchangeSelect.addEventListener('change', applyFilters);
      industrySelect.addEventListener('change', applyFilters);

      // Initial filter apply to set pagination
      applyFilters();
    });
  </script>
</Layout>
