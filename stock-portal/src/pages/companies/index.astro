---
import Layout from '../../layouts/Layout.astro';
import { fetchCompanies } from '../../lib/api';

let companies = [];
let errorMsg = "";

try {
  companies = await fetchCompanies();
} catch (e: any) {
  errorMsg = e.message;
  // Premium fallback mock data
  companies = [
    { symbol: 'HPG', name: 'Tập đoàn Hòa Phát', exchange: 'HOSE', industry: 'Thép', hasBusinessModel: true, hasResearch: true, docCount: 12 },
    { symbol: 'HSG', name: 'Tập đoàn Hoa Sen', exchange: 'HOSE', industry: 'Thép', hasBusinessModel: true, hasResearch: false, docCount: 6 },
    { symbol: 'NKG', name: 'Thép Nam Kim', exchange: 'HOSE', industry: 'Thép', hasBusinessModel: true, hasResearch: false, docCount: 4 },
    { symbol: 'VCB', name: 'Ngân hàng Vietcombank', exchange: 'HOSE', industry: 'Ngân hàng', hasBusinessModel: true, hasResearch: true, docCount: 15 },
    { symbol: 'ACB', name: 'Ngân hàng ACB', exchange: 'HNX', industry: 'Ngân hàng', hasBusinessModel: true, hasResearch: true, docCount: 8 },
    { symbol: 'BID', name: 'Ngân hàng BIDV', exchange: 'HOSE', industry: 'Ngân hàng', hasBusinessModel: false, hasResearch: false, docCount: 3 },
    { symbol: 'CTG', name: 'VietinBank', exchange: 'HOSE', industry: 'Ngân hàng', hasBusinessModel: false, hasResearch: true, docCount: 5 },
    { symbol: 'MBB', name: 'Ngân hàng Quân Đội', exchange: 'HOSE', industry: 'Ngân hàng', hasBusinessModel: true, hasResearch: false, docCount: 7 },
    { symbol: 'VND', name: 'Chứng khoán VNDirect', exchange: 'HOSE', industry: 'Chứng khoán', hasBusinessModel: true, hasResearch: false, docCount: 9 },
    { symbol: 'SSI', name: 'Chứng khoán SSI', exchange: 'HOSE', industry: 'Chứng khoán', hasBusinessModel: true, hasResearch: true, docCount: 14 },
    { symbol: 'VCI', name: 'Chứng khoán Vietcap', exchange: 'HOSE', industry: 'Chứng khoán', hasBusinessModel: true, hasResearch: false, docCount: 5 },
    { symbol: 'FPT', name: 'Tập đoàn FPT', exchange: 'HOSE', industry: 'Công nghệ', hasBusinessModel: true, hasResearch: true, docCount: 20 },
    { symbol: 'MWG', name: 'Thế Giới Di Động', exchange: 'HOSE', industry: 'Bán lẻ', hasBusinessModel: true, hasResearch: true, docCount: 11 },
    { symbol: 'PNJ', name: 'Vàng bạc Phú Nhuận', exchange: 'HOSE', industry: 'Bán lẻ', hasBusinessModel: false, hasResearch: false, docCount: 4 },
    { symbol: 'VNM', name: 'Vinamilk', exchange: 'HOSE', industry: 'Thực phẩm', hasBusinessModel: true, hasResearch: true, docCount: 13 },
    { symbol: 'VIC', name: 'Tập đoàn Vingroup', exchange: 'HOSE', industry: 'Bất động sản', hasBusinessModel: false, hasResearch: false, docCount: 8 },
    { symbol: 'VHM', name: 'Vinhomes', exchange: 'HOSE', industry: 'Bất động sản', hasBusinessModel: true, hasResearch: true, docCount: 10 }
  ];
}

// Generate unique list of industries for filtering
const industries = [...new Set(companies.map(c => c.industry).filter(Boolean))].sort();
---

<Layout title="Mô hình kinh doanh & Chuỗi giá trị - Stock Portal">
  <div class="flex flex-col gap-8 py-2">
    <!-- Header -->
    <div class="border-l-4 border-primary pl-4 py-1">
      <h1 class="text-3xl font-extrabold tracking-tight font-display text-foreground">
        Hệ Thống Mô Hình Kinh Doanh
      </h1>
      <p class="text-sm text-muted-foreground mt-1 max-w-xl">
        Tra cứu nhanh mô hình hoạt động, cơ cấu dòng doanh thu, chi phí sản xuất và chuỗi giá trị của các doanh nghiệp niêm yết.
      </p>
    </div>

    <!-- Filter Bar -->
    <div class="bg-card border border-border rounded-2xl p-5 flex flex-col gap-4 shadow-sm">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-4">
        <!-- Search Input -->
        <div class="lg:col-span-6 relative flex items-center bg-background border border-input rounded-xl px-3 py-1.5 focus-within:border-primary focus-within:ring-2 focus-within:ring-primary/10 transition-all">
          <svg class="w-4 h-4 text-muted-foreground ml-1 flex-shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <input 
            type="text" 
            id="grid-search" 
            placeholder="Tìm kiếm mã cổ phiếu hoặc tên doanh nghiệp..." 
            autocomplete="off"
            class="w-full border-none bg-transparent px-3 py-2 text-sm text-foreground outline-none placeholder:text-muted-foreground"
          />
        </div>

        <div class="lg:col-span-6 grid grid-cols-1 sm:grid-cols-3 gap-3">
          <!-- Exchange Filter -->
          <div class="relative">
            <select 
              id="filter-exchange" 
              aria-label="Lọc theo Sàn giao dịch"
              class="w-full bg-background border border-input text-foreground text-sm rounded-xl px-3 py-3 font-medium outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all appearance-none cursor-pointer"
            >
              <option value="all">Tất cả các Sàn</option>
              <option value="HOSE">Sàn HOSE</option>
              <option value="HNX">Sàn HNX</option>
              <option value="UPCOM">Sàn UPCOM</option>
            </select>
            <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-3 text-muted-foreground">
              <svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg>
            </div>
          </div>

          <!-- Industry Filter -->
          <div class="relative">
            <select 
              id="filter-industry" 
              aria-label="Lọc theo Ngành nghề"
              class="w-full bg-background border border-input text-foreground text-sm rounded-xl px-3 py-3 font-medium outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all appearance-none cursor-pointer"
            >
              <option value="all">Tất cả các Ngành</option>
              {industries.map(ind => (
                <option value={ind}>{ind}</option>
              ))}
            </select>
            <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-3 text-muted-foreground">
              <svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg>
            </div>
          </div>

          <!-- Data Type Filter -->
          <div class="relative">
            <select 
              id="filter-data-type" 
              aria-label="Lọc theo Loại dữ liệu"
              class="w-full bg-background border border-input text-foreground text-sm rounded-xl px-3 py-3 font-medium outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all appearance-none cursor-pointer"
            >
              <option value="all">Tất cả dữ liệu</option>
              <option value="has-bm">Có Chuỗi giá trị</option>
              <option value="has-research">Có Nghiên cứu</option>
              <option value="has-docs">Có BCTC/Tài liệu</option>
            </select>
            <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-3 text-muted-foreground">
              <svg class="fill-current h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20"><path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z"/></svg>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Results count meta -->
    <div class="text-sm font-semibold text-muted-foreground flex items-center gap-1.5 pl-1">
      <span>Tìm thấy</span>
      <span id="results-count" class="text-primary font-bold text-base">{companies.length}</span>
      <span>doanh nghiệp phù hợp bộ lọc</span>
    </div>

    <!-- Error alert if API fails -->
    {errorMsg && (
      <div class="flex items-center gap-3 bg-rose-500/10 border border-rose-500/20 text-rose-500 rounded-xl p-4 text-sm font-medium">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 flex-shrink-0">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
        </svg>
        <span>Chế độ ngoại tuyến: Hiển thị danh sách doanh nghiệp mẫu. (Chi tiết: {errorMsg})</span>
      </div>
    )}

    <!-- Company Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6" id="companies-grid">
      {companies.map(company => (
        <a 
          href={`/companies/${company.symbol}`} 
          class="group bg-card border border-border hover:border-primary p-5 rounded-2xl transition-all duration-300 transform hover:-translate-y-1 hover:shadow-md flex flex-col gap-4 company-card" 
          data-symbol={company.symbol}
          data-name={company.name}
          data-exchange={company.exchange}
          data-industry={company.industry || ''}
          data-has-bm={company.hasBusinessModel ? "true" : "false"}
          data-has-research={company.hasResearch ? "true" : "false"}
          data-doc-count={company.docCount || 0}
        >
          <div class="flex justify-between items-center">
            <span class="font-display font-extrabold text-2xl text-foreground group-hover:text-primary transition-colors">{company.symbol}</span>
            <span class={`text-xs font-extrabold px-2.5 py-0.5 rounded border border-border ${company.exchange === 'HOSE' ? 'text-rose-500 bg-rose-500/5 border-rose-500/20' : company.exchange === 'HNX' ? 'text-blue-500 bg-blue-500/5 border-blue-500/20' : 'text-slate-500 bg-slate-500/5'}`}>{company.exchange}</span>
          </div>
          <h2 class="text-base font-bold text-foreground leading-snug line-clamp-1">{company.name}</h2>
          
          <div class="flex items-center justify-between gap-2 mt-auto pt-2 border-t border-border/60">
            <span class="inline-flex items-center gap-1.5 text-xs font-semibold text-muted-foreground bg-muted/60 px-2.5 py-1 rounded-full border border-border">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3.5 h-3.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
              </svg>
              {company.industry || 'Chưa phân ngành'}
            </span>
            <div class="flex gap-1">
              {company.hasBusinessModel && <span class="text-[10px] font-extrabold px-1.5 py-0.5 rounded bg-teal-500/10 text-teal-600 border border-teal-500/20 uppercase" title="Có chuỗi giá trị">🔗 BM</span>}
              {company.hasResearch && <span class="text-[10px] font-extrabold px-1.5 py-0.5 rounded bg-blue-500/10 text-blue-600 border border-blue-500/20 uppercase" title="Có báo cáo nghiên cứu">📊 SSI</span>}
              {company.docCount && company.docCount > 0 ? <span class="text-[10px] font-extrabold px-1.5 py-0.5 rounded bg-orange-500/10 text-orange-600 border border-orange-500/20 uppercase" title={`Có ${company.docCount} tài liệu tài chính`}>📄 AI</span> : null}
            </div>
          </div>
        </a>
      ))}
    </div>

    <!-- Empty State -->
    <div class="hidden flex-col items-center justify-center text-center gap-4 py-16 px-4 bg-card border border-dashed border-border rounded-2xl" id="empty-state">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-12 h-12 text-muted-foreground">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15.182 16.318A4.486 4.486 0 0012.016 15a4.486 4.486 0 00-3.198 1.302m0-6.098a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0zm9 0a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0zM12 21a9.003 9.003 0 008.354-5.646 9.003 9.003 0 00-8.354.343M12 21a9.003 9.003 0 01-8.354-5.646 9.003 9.003 0 018.354.343M12 3a9 9 0 000 18 9 9 0 000-18z" />
      </svg>
      <h3 class="text-lg font-bold text-foreground font-display">Không tìm thấy doanh nghiệp nào</h3>
      <p class="text-sm text-muted-foreground max-w-xs">Vui lòng thử lại với từ khóa tìm kiếm hoặc bộ lọc khác.</p>
    </div>

    <!-- Load More Button -->
    <div class="hidden text-center mt-6" id="pagination-container">
      <button id="load-more-btn" class="bg-card border border-border text-foreground hover:bg-muted font-bold text-sm px-6 py-3 rounded-full shadow-sm hover:scale-102 transition-all duration-200 min-h-[44px]">
        Xem thêm doanh nghiệp
      </button>
    </div>
  </div>

  <!-- Client-side Instant Filter script -->
  <script is:inline>
    function removeVietnameseTones(str) {
      return str
        .normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '')
        .replace(/đ/g, 'd')
        .replace(/Đ/g, 'd')
        .toLowerCase();
    }

    function debounce(func, wait) {
      let timeout;
      return function(...args) {
        clearTimeout(timeout);
        timeout = setTimeout(() => func.apply(this, args), wait);
      };
    }

    document.addEventListener('DOMContentLoaded', () => {
      const searchInput = document.getElementById('grid-search');
      const exchangeSelect = document.getElementById('filter-exchange');
      const industrySelect = document.getElementById('filter-industry');
      const dataTypeSelect = document.getElementById('filter-data-type');
      const countDisplay = document.getElementById('results-count');
      const cards = Array.from(document.querySelectorAll('.company-card'));
      const emptyState = document.getElementById('empty-state');
      const loadMoreBtn = document.getElementById('load-more-btn');
      const paginationContainer = document.getElementById('pagination-container');

      const PAGE_SIZE = 50;
      let visibleCount = PAGE_SIZE;
      let currentFilteredCards = [...cards];

      const applyFilters = () => {
        const query = searchInput.value.trim().toLowerCase();
        const normalizedQuery = removeVietnameseTones(query);
        const exchange = exchangeSelect.value;
        const industry = industrySelect.value;
        const dataType = dataTypeSelect.value;

        currentFilteredCards = cards.filter(card => {
          if (exchange !== 'all' && card.getAttribute('data-exchange') !== exchange) {
            return false;
          }

          if (industry !== 'all' && card.getAttribute('data-industry') !== industry) {
            return false;
          }

          if (dataType !== 'all') {
            const hasBm = card.getAttribute('data-has-bm') === 'true';
            const hasResearch = card.getAttribute('data-has-research') === 'true';
            const docCount = parseInt(card.getAttribute('data-doc-count') || '0', 10);

            if (dataType === 'has-bm' && !hasBm) return false;
            if (dataType === 'has-research' && !hasResearch) return false;
            if (dataType === 'has-docs' && docCount <= 0) return false;
          }

          if (query) {
            const symbol = card.getAttribute('data-symbol').toLowerCase();
            const name = card.getAttribute('data-name').toLowerCase();
            const normalizedSymbol = removeVietnameseTones(symbol);
            const normalizedName = removeVietnameseTones(name);

            const matchSymbol = symbol.includes(query) || normalizedSymbol.includes(normalizedQuery);
            const matchName = name.includes(query) || normalizedName.includes(normalizedQuery);

            if (!matchSymbol && !matchName) {
              return false;
            }
          }

          return true;
        });

        cards.forEach(card => card.style.display = 'none');
        countDisplay.textContent = currentFilteredCards.length;

        if (currentFilteredCards.length === 0) {
          emptyState.classList.remove('hidden');
          emptyState.classList.add('flex');
          paginationContainer.classList.add('hidden');
          return;
        } else {
          emptyState.classList.add('hidden');
          emptyState.classList.remove('flex');
        }

        visibleCount = PAGE_SIZE;
        renderPaginated();
      };

      const renderPaginated = () => {
        const toShow = currentFilteredCards.slice(0, visibleCount);
        toShow.forEach(card => {
          card.classList.remove('hidden');
          card.style.display = 'flex';
        });

        if (visibleCount < currentFilteredCards.length) {
          paginationContainer.classList.remove('hidden');
        } else {
          paginationContainer.classList.add('hidden');
        }
      };

      if (loadMoreBtn) {
        loadMoreBtn.addEventListener('click', () => {
          visibleCount += PAGE_SIZE;
          renderPaginated();
        });
      }

      searchInput.addEventListener('input', debounce(applyFilters, 250));
      exchangeSelect.addEventListener('change', applyFilters);
      industrySelect.addEventListener('change', applyFilters);
      dataTypeSelect.addEventListener('change', applyFilters);

      applyFilters();
    });
  </script>
</Layout>
