---
import Layout from '../../layouts/Layout.astro';
import { fetchCompanies } from '../../lib/api';

let companiesWithDocs = [];
let errorMsg = "";

try {
  const companies = await fetchCompanies();
  companiesWithDocs = companies
    .filter(c => c.docCount && c.docCount > 0)
    .sort((a, b) => {
      const indComp = (a.industry || '').localeCompare(b.industry || '', 'vi');
      if (indComp !== 0) return indComp;
      return a.symbol.localeCompare(b.symbol);
    });
} catch (e: any) {
  errorMsg = e.message;
  const mockCompanies = [
    { symbol: 'HPG', name: 'Tập đoàn Hòa Phát', exchange: 'HOSE', industry: 'Thép', hasBusinessModel: true, hasResearch: true, docCount: 12 },
    { symbol: 'HSG', name: 'Tập đoàn Hoa Sen', exchange: 'HOSE', industry: 'Thép', hasBusinessModel: true, hasResearch: false, docCount: 6 },
    { symbol: 'VCB', name: 'Ngân hàng Vietcombank', exchange: 'HOSE', industry: 'Ngân hàng', hasBusinessModel: true, hasResearch: true, docCount: 15 },
    { symbol: 'ACB', name: 'Ngân hàng ACB', exchange: 'HNX', industry: 'Ngân hàng', hasBusinessModel: true, hasResearch: true, docCount: 8 },
    { symbol: 'FPT', name: 'Tập đoàn FPT', exchange: 'HOSE', industry: 'Công nghệ', hasBusinessModel: true, hasResearch: true, docCount: 20 },
    { symbol: 'MWG', name: 'Thế Giới Di Động', exchange: 'HOSE', industry: 'Bán lẻ', hasBusinessModel: true, hasResearch: true, docCount: 11 },
    { symbol: 'VNM', name: 'Vinamilk', exchange: 'HOSE', industry: 'Thực phẩm', hasBusinessModel: true, hasResearch: true, docCount: 13 },
    { symbol: 'VHM', name: 'Vinhomes', exchange: 'HOSE', industry: 'Bất động sản', hasBusinessModel: true, hasResearch: true, docCount: 10 }
  ];
  companiesWithDocs = mockCompanies
    .filter(c => c.docCount && c.docCount > 0)
    .sort((a, b) => {
      const indComp = (a.industry || '').localeCompare(b.industry || '', 'vi');
      if (indComp !== 0) return indComp;
      return a.symbol.localeCompare(b.symbol);
    });
}

// Gom nhóm các doanh nghiệp theo Ngành để phân mục rõ ràng
const groupedCompanies: Record<string, typeof companiesWithDocs> = {};
companiesWithDocs.forEach(c => {
  const ind = c.industry || 'Chưa phân ngành';
  if (!groupedCompanies[ind]) {
    groupedCompanies[ind] = [];
  }
  groupedCompanies[ind].push(c);
});

// Sắp xếp các ngành theo tiếng Việt
const sortedIndustries = Object.keys(groupedCompanies).sort((a, b) => a.localeCompare(b, 'vi'));
---

<Layout title="Báo Cáo Tài Chính Cho AI Đọc - Stock Portal">
  <div class="container docs-page">
    <div class="page-header">
      <h1 class="page-title">Báo Cáo Tài Chính Cho AI Đọc</h1>
      <p class="page-desc">Danh sách báo cáo tài chính của các doanh nghiệp đã được số hóa định dạng thân thiện với AI, giúp nhà đầu tư dễ dàng tra cứu và phân tích.</p>
    </div>

    <!-- Search Bar (Client-side filter for company symbols & names) -->
    <div class="filter-bar">
      <div class="search-field">
        <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
        <input type="text" id="company-search" placeholder="Tìm kiếm doanh nghiệp theo mã hoặc tên..." autocomplete="off" />
      </div>
    </div>

    {errorMsg && (
      <div class="error-banner">
        <p>Lỗi kết nối dữ liệu: {errorMsg}</p>
      </div>
    )}

    <!-- Grouped Companies Accordion List -->
    <div class="industry-groups-container" id="industry-groups">
      {sortedIndustries.map(industry => (
        <div class="industry-group-section mb-6" data-industry={industry}>
          <h2 class="industry-title flex items-center gap-2 text-base font-extrabold text-foreground mb-3 px-1 font-display">
            <span class="w-1.5 h-3.5 bg-primary rounded-full"></span>
            {industry}
          </h2>
          
          <div class="companies-grid grid grid-cols-1 md:grid-cols-2 gap-4">
            {groupedCompanies[industry].map(company => (
              <div 
                class="company-card-accordion bg-card border border-border rounded-xl overflow-hidden shadow-sm hover:border-primary/50 transition-all"
                data-symbol={company.symbol}
                data-name={company.name}
              >
                <!-- Accordion Header -->
                <button 
                  class="accordion-header w-full flex items-center justify-between p-4 text-left transition-colors hover:bg-muted/10 cursor-pointer"
                  data-symbol={company.symbol}
                  aria-expanded="false"
                >
                  <div class="flex items-center gap-3">
                    <span class="symbol-badge font-display font-extrabold text-sm bg-primary/10 text-primary border border-primary/20 px-2.5 py-1 rounded-lg">
                      {company.symbol}
                    </span>
                    <div>
                      <h3 class="text-sm font-bold text-foreground leading-snug">{company.name}</h3>
                      <span class="text-xs text-muted-foreground">{company.docCount} báo cáo tài chính</span>
                    </div>
                  </div>
                  
                  <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4 text-muted-foreground arrow-icon transition-transform duration-200">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                  </svg>
                </button>
                
                <!-- Accordion Content -->
                <div class="accordion-content hidden border-t border-border/50 bg-muted/5 max-h-0 overflow-hidden transition-all duration-300" id={`accordion-content-${company.symbol}`}>
                  <div class="doc-sublist p-2" data-loaded="false">
                    <!-- Loaded dynamically via JS -->
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}

      {companiesWithDocs.length === 0 && !errorMsg && (
        <div class="empty-state">
          <h3>Chưa có dữ liệu</h3>
          <p>Hiện tại hệ thống chưa cập nhật báo cáo tài chính nào.</p>
        </div>
      )}
    </div>

    <!-- Client-side Empty State -->
    <div class="empty-state" id="client-empty-state" style="display: none;">
      <h3>Không tìm thấy doanh nghiệp</h3>
      <p>Thử tìm kiếm với mã hoặc tên doanh nghiệp khác.</p>
    </div>
  </div>

  <style>
    .docs-page {
      display: flex;
      flex-direction: column;
      gap: 2rem;
      padding-top: 1rem;
      padding-bottom: 5rem;
    }

    .page-header {
      border-left: 4px solid var(--accent-primary);
      padding-left: 1rem;
    }

    .page-title {
      font-size: clamp(1.75rem, 5vw, 2.25rem);
      font-weight: 800;
      letter-spacing: -0.025em;
      margin-bottom: 0.5rem;
      font-family: var(--font-display);
    }

    .page-desc {
      color: var(--text-secondary);
      font-size: 1rem;
      max-width: 600px;
    }

    .filter-bar {
      background: var(--bg-secondary);
      border: 1px solid var(--border-color);
      border-radius: 16px;
      padding: 1.25rem;
      box-shadow: var(--shadow-sm);
    }

    .search-field {
      position: relative;
      display: flex;
      align-items: center;
    }

    .search-icon {
      position: absolute;
      left: 1rem;
      width: 20px;
      height: 20px;
      color: var(--text-muted);
      pointer-events: none;
    }

    #company-search {
      width: 100%;
      background: var(--bg-primary);
      border: 1px solid var(--border-color);
      border-radius: 9999px;
      padding: 0.75rem 1rem 0.75rem 2.75rem;
      font-size: 0.95rem;
      color: var(--text-primary);
      outline: none;
      transition: all 0.25s ease;
    }

    #company-search:focus {
      border-color: var(--accent-primary);
      box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
    }

    .error-banner {
      background: rgba(239, 68, 68, 0.1);
      border: 1px solid rgba(239, 68, 68, 0.2);
      border-radius: 12px;
      padding: 1rem;
      color: #ef4444;
      font-weight: 500;
    }

    .empty-state {
      padding: 4rem 1.5rem;
      text-align: center;
      background: var(--bg-secondary);
      border: 1px dashed var(--border-color);
      border-radius: 16px;
    }

    .empty-state h3 {
      font-size: 1.2rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
    }

    .empty-state p {
      color: var(--text-secondary);
      font-size: 0.95rem;
    }

    .arrow-icon.rotate-180 {
      transform: rotate(180deg);
    }
  </style>

  <script is:inline>
    function removeVietnameseTones(str) {
      return str
        .normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '')
        .replace(/đ/g, 'd')
        .replace(/Đ/g, 'd')
        .toLowerCase();
    }

    document.addEventListener('DOMContentLoaded', () => {
      const searchInput = document.getElementById('company-search');
      const companyCards = document.querySelectorAll('.company-card-accordion');
      const industryGroups = document.querySelectorAll('.industry-group-section');
      const clientEmptyState = document.getElementById('client-empty-state');

      // 1. Client-side Search Filter
      const filterCompanies = () => {
        const query = searchInput.value.trim().toLowerCase();
        const normalizedQuery = removeVietnameseTones(query);
        let totalVisible = 0;

        industryGroups.forEach(group => {
          let visibleInGroup = 0;
          const cards = group.querySelectorAll('.company-card-accordion');

          cards.forEach(card => {
            const symbol = card.getAttribute('data-symbol').toLowerCase();
            const name = card.getAttribute('data-name').toLowerCase();
            const normalizedName = removeVietnameseTones(name);

            if (symbol.includes(query) || name.includes(query) || normalizedName.includes(normalizedQuery)) {
              card.style.display = 'block';
              visibleInGroup++;
              totalVisible++;
            } else {
              card.style.display = 'none';
            }
          });

          // Ẩn tiêu đề nhóm ngành nếu không có DN nào thỏa mãn bộ lọc
          if (visibleInGroup === 0) {
            group.style.display = 'none';
          } else {
            group.style.display = 'block';
          }
        });

        if (totalVisible === 0 && companyCards.length > 0) {
          clientEmptyState.style.display = 'block';
        } else {
          clientEmptyState.style.display = 'none';
        }
      };

      searchInput.addEventListener('input', () => {
        filterCompanies();
      });

      // 2. Accordion dynamic loading
      const accordionHeaders = document.querySelectorAll('.accordion-header');
      
      accordionHeaders.forEach(header => {
        header.addEventListener('click', async () => {
          const symbol = header.getAttribute('data-symbol');
          const contentEl = document.getElementById(`accordion-content-${symbol}`);
          const isExpanded = header.getAttribute('aria-expanded') === 'true';
          const arrow = header.querySelector('.arrow-icon');
          
          if (isExpanded) {
            header.setAttribute('aria-expanded', 'false');
            contentEl.classList.add('hidden');
            contentEl.style.maxHeight = '0px';
            arrow.classList.remove('rotate-180');
          } else {
            header.setAttribute('aria-expanded', 'true');
            contentEl.classList.remove('hidden');
            contentEl.style.maxHeight = '2000px'; // Allow expansion for many items
            arrow.classList.add('rotate-180');
            
            // Check if already loaded
            const listEl = contentEl.querySelector('.doc-sublist');
            if (listEl.getAttribute('data-loaded') === 'false') {
              listEl.innerHTML = '<div class="loading-state py-4 text-xs text-muted-foreground text-center">Đang tải báo cáo tài chính...</div>';
              
              try {
                const response = await fetch(`/api/documents?symbol=${symbol}&per_page=50`);
                const data = await response.json();
                
                if (data.success && data.result.length > 0) {
                  listEl.innerHTML = '';
                  
                  data.result.forEach(doc => {
                    const li = document.createElement('div');
                    li.className = 'sublist-item flex items-center justify-between p-3 border-b border-border/40 last:border-b-0 hover:bg-muted/10 transition-colors';
                    li.innerHTML = `
                      <div class="flex flex-col gap-0.5">
                        <span class="text-sm font-semibold text-foreground leading-snug">${doc.fileName}</span>
                        <span class="text-xs text-muted-foreground">Năm tài chính: ${doc.year} ${doc.label ? `• ${doc.label}` : ''}</span>
                      </div>
                      <a href="${doc.fileUrl}" target="_blank" rel="noopener noreferrer" class="read-ai-btn text-xs font-bold text-primary border border-primary/20 px-3.5 py-1.5 rounded-lg hover:bg-primary hover:text-white transition-all min-h-[38px] flex items-center justify-center whitespace-nowrap">
                        Đọc bằng AI →
                      </a>
                    `;
                    listEl.appendChild(li);
                  });
                  
                  listEl.setAttribute('data-loaded', 'true');
                } else {
                  listEl.innerHTML = '<div class="py-4 text-xs text-muted-foreground text-center">Không tìm thấy báo cáo nào.</div>';
                }
              } catch (e) {
                console.error(e);
                listEl.innerHTML = '<div class="py-4 text-xs text-red-500 text-center">Lỗi tải dữ liệu. Vui lòng thử lại.</div>';
              }
            }
          }
        });
      });
    });
  </script>
</Layout>
