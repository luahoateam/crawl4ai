---
import Layout from '../layouts/Layout.astro';
import { fetchCompanies, fetchStats, fetchGlobalDocuments, fetchGlobalResearch } from '../lib/api';

let companies = [];
let stats = { companies: 1617, businessModels: 1429, dailyResearch: 560, news: 14888, documents: 18185 };
let researchFeed = [];
let docsFeed = [];
let errorMsg = "";

// Check auth token
const token = Astro.cookies.get('token')?.value;
const isLoggedIn = !!token;

try {
  companies = await fetchCompanies();
} catch (e: any) {
  errorMsg = e.message;
  // Fallback mock companies for premium offline/error resilience
  companies = [
    { symbol: 'HPG', name: 'Tập đoàn Hòa Phát', exchange: 'HOSE', industry: 'Thép' },
    { symbol: 'HSG', name: 'Tập đoàn Hoa Sen', exchange: 'HOSE', industry: 'Thép' },
    { symbol: 'VCB', name: 'Ngân hàng Vietcombank', exchange: 'HOSE', industry: 'Ngân hàng' },
    { symbol: 'ACB', name: 'Ngân hàng ACB', exchange: 'HNX', industry: 'Ngân hàng' },
    { symbol: 'VND', name: 'Chứng khoán VNDirect', exchange: 'HOSE', industry: 'Chứng khoán' },
    { symbol: 'SSI', name: 'Chứng khoán SSI', exchange: 'HOSE', industry: 'Chứng khoán' },
    { symbol: 'FPT', name: 'Tập đoàn FPT', exchange: 'HOSE', industry: 'Công nghệ' },
    { symbol: 'MWG', name: 'Thế Giới Di Động', exchange: 'HOSE', industry: 'Bán lẻ' },
    { symbol: 'VNM', name: 'Sữa Việt Nam (Vinamilk)', exchange: 'HOSE', industry: 'Thực phẩm' },
    { symbol: 'VIC', name: 'Tập đoàn Vingroup', exchange: 'HOSE', industry: 'Bất động sản' }
  ];
}

try {
  stats = await fetchStats();
} catch (e) {}

try {
  const researchRes = await fetchGlobalResearch({ perPage: 4 });
  researchFeed = researchRes.result || [];
} catch (e) {}

try {
  const docsRes = await fetchGlobalDocuments({ perPage: 4 });
  docsFeed = docsRes.result || [];
} catch (e) {}

const totalCount = stats.companies;
const hoseCount = companies.filter(c => c.exchange === 'HOSE').length || 423;
const hnxCount = companies.filter(c => c.exchange === 'HNX').length || 342;
const upcomCount = companies.filter(c => c.exchange === 'UPCOM').length || 646;

// VN30 Hardcode symbols
const VN30_SYMBOLS = ['VCB', 'VIC', 'VHM', 'HPG', 'GAS', 'BID', 'CTG', 'MBB', 'TCB', 'ACB', 'MSN', 'VNM', 'SAB', 'VPB', 'STB', 'FPT', 'MWG', 'SSI', 'VRE', 'POW', 'PLX', 'HDB', 'EIB', 'VJC', 'KDH', 'PDR', 'NVL', 'DIG', 'SHB', 'BCM'];
const vn30Companies = companies
  .filter(c => VN30_SYMBOLS.includes(c.symbol.toUpperCase()))
  .sort((a, b) => {
    const indComp = (a.industry || '').localeCompare(b.industry || '', 'vi');
    if (indComp !== 0) return indComp;
    return a.symbol.localeCompare(b.symbol);
  });
---

<Layout title="Stock Portal - Tra cứu doanh nghiệp & Báo cáo tài chính cho AI đọc">
  <div class="flex flex-col gap-16 pb-16">
    <!-- Hero Section -->
    <section class="relative py-16 text-center overflow-hidden flex flex-col items-center gap-6">
      <div class="inline-flex items-center gap-2 px-3 py-1 text-xs font-semibold uppercase tracking-wider text-primary bg-muted border border-border rounded-full shadow-sm">
        Trọng tâm: Mô hình kinh doanh & Báo cáo tài chính AI
      </div>
      <h1 class="text-4xl sm:text-5xl md:text-6xl font-extrabold tracking-tight leading-tight flex flex-col gap-2 font-display text-foreground">
        <span>Khám Phá Mô Hình Kinh Doanh &</span>
        <span class="bg-gradient-to-r from-primary to-emerald-500 bg-clip-text text-transparent">Báo Cáo Tài Chính Cho AI Đọc</span>
      </h1>
      <p class="text-lg text-muted-foreground max-w-2xl leading-relaxed">
        Phân tích chuỗi giá trị doanh nghiệp niêm yết, dòng doanh thu, chi phí sản xuất, báo cáo tài chính định dạng tối ưu cho AI và nghiên cứu SSI chuyên sâu.
      </p>

      <!-- Search Auto-complete Component -->
      <div class="relative w-full max-w-2xl z-10 mt-4" id="search-box-wrapper" data-companies={JSON.stringify(companies)}>
        <div class="relative flex items-center bg-card border-2 border-border rounded-full px-3 py-1.5 shadow-md focus-within:border-primary focus-within:ring-4 focus-within:ring-primary/15 transition-all duration-300 transform focus-within:-translate-y-0.5">
          <svg class="w-5 h-5 text-muted-foreground ml-3 flex-shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          <input 
            type="text" 
            id="search-input" 
            placeholder="Nhập mã cổ phiếu (ví dụ: HPG, VCB, FPT...) hoặc tên ngành..." 
            autocomplete="off"
            class="w-full border-none bg-transparent px-3 py-3 text-base text-foreground font-sans outline-none placeholder:text-muted-foreground"
          />
          <button id="clear-search" class="hidden items-center justify-center p-2 rounded-full text-muted-foreground hover:bg-muted hover:text-foreground transition-colors mr-2 min-h-[44px] min-w-[44px]">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="size-5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
        <!-- Dropdown items -->
        <div class="absolute top-full left-0 right-0 mt-3 bg-card border border-border rounded-2xl shadow-xl text-left overflow-hidden hidden" id="autocomplete-dropdown">
          <div class="px-5 py-3 text-xs font-bold uppercase tracking-wider text-muted-foreground border-b border-border bg-muted/50">
            Kết quả gợi ý
          </div>
          <div class="max-h-[380px] overflow-y-auto" id="dropdown-results"></div>
        </div>
      </div>
    </section>

    <!-- Stats Section -->
    <section class="py-4">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="bg-card border border-border rounded-2xl p-6 text-center shadow-sm hover:shadow-md hover:border-primary transition-all duration-300 transform hover:-translate-y-1">
          <div class="font-display text-4xl font-extrabold text-primary mb-2 stat-companies">{totalCount}</div>
          <div class="text-sm font-semibold text-muted-foreground">Mô hình kinh doanh doanh nghiệp</div>
        </div>
        <div class="bg-card border border-border rounded-2xl p-6 text-center shadow-sm hover:shadow-md hover:border-primary transition-all duration-300 transform hover:-translate-y-1">
          <div class="font-display text-4xl font-extrabold text-foreground mb-2">{hoseCount}</div>
          <div class="text-sm font-semibold text-muted-foreground">Cổ phiếu sàn HOSE</div>
        </div>
        <div class="bg-card border border-border rounded-2xl p-6 text-center shadow-sm hover:shadow-md hover:border-primary transition-all duration-300 transform hover:-translate-y-1">
          <div class="font-display text-4xl font-extrabold text-foreground mb-2">{hnxCount}</div>
          <div class="text-sm font-semibold text-muted-foreground">Cổ phiếu sàn HNX</div>
        </div>
        <div class="bg-card border border-border rounded-2xl p-6 text-center shadow-sm hover:shadow-md hover:border-primary transition-all duration-300 transform hover:-translate-y-1">
          <div class="font-display text-4xl font-extrabold text-foreground mb-2">{upcomCount}</div>
          <div class="text-sm font-semibold text-muted-foreground">Cổ phiếu sàn UPCOM</div>
        </div>
      </div>
    </section>

    <!-- Banner 10,000+ Hours of Labor -->
    <section class="py-2">
      <div class="bg-gradient-to-r from-blue-600/10 via-primary/5 to-emerald-500/10 border border-primary/20 rounded-2xl p-6 flex flex-col md:flex-row items-center justify-between gap-6 shadow-sm">
        <div class="flex items-center gap-4 text-left">
          <div class="text-3xl sm:text-4xl">📋</div>
          <div>
            <h3 class="text-base font-extrabold text-foreground tracking-tight font-display">
              Hơn {stats.documents.toLocaleString('vi-VN')} Báo Cáo Tài Chính Đã Được Số Hóa Cho AI Đọc
            </h3>
            <p class="text-sm text-muted-foreground mt-1 max-w-2xl leading-relaxed">
              Tương đương <strong>10,000+ giờ lao động</strong> nhập liệu thủ công, giúp nhà đầu tư cá nhân dễ dàng tiếp cận sâu sát với tình hình kinh doanh thực tế của doanh nghiệp.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Documents Section (Báo cáo tài chính cho AI đọc) -->
    <section class="flex flex-col gap-6">
      <div class="flex items-center justify-between border-l-4 border-primary pl-4">
        <h2 class="text-2xl font-bold text-foreground font-display">Báo Cáo Tài Chính Cho AI Đọc</h2>
        <a href="/documents" class="text-sm font-semibold text-primary hover:underline flex items-center gap-1">
          Xem tất cả &rarr;
        </a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {docsFeed.map((item) => (
          <div class="bg-card border border-border rounded-2xl p-5 flex flex-col gap-4 shadow-sm hover:shadow-md hover:border-primary transition-all duration-200">
            <span class="inline-flex self-start text-xs font-bold px-2 py-1 rounded bg-primary/10 text-primary hover:bg-primary/20 transition-colors">
              <a href={`/companies/${item.symbol}`}>{item.symbol}</a>
            </span>
            <h3 class="text-sm font-semibold text-foreground leading-snug line-clamp-2 min-h-[2.8rem]">
              {item.fileName}
            </h3>
            <div class="flex justify-between items-center text-xs text-muted-foreground mt-2">
              <span>Năm {item.year}</span>
              <span class="bg-muted px-2 py-0.5 rounded border border-border font-medium">{item.label || 'BCTC'}</span>
            </div>
            <a 
              href={item.fileUrl} 
              class="w-full bg-muted border border-border text-foreground hover:bg-primary hover:text-primary-foreground hover:border-primary text-center py-2.5 rounded-lg text-sm font-bold transition-all duration-200 mt-auto min-h-[44px] flex items-center justify-center" 
              target="_blank" 
              rel="noopener noreferrer"
            >
              Đọc bằng AI
            </a>
          </div>
        ))}
        {docsFeed.length === 0 && (
          <div class="col-span-full py-12 text-center text-muted-foreground border border-dashed border-border rounded-2xl bg-card">
            Chưa có tài liệu tài chính AI mới.
          </div>
        )}
      </div>
    </section>

    <!-- VN30 Section (Mô hình kinh doanh mặc định nhóm VN30) -->
    <section class="flex flex-col gap-6">
      <div class="flex items-center justify-between border-l-4 border-primary pl-4">
        <div>
          <h2 class="text-2xl font-bold text-foreground font-display flex items-center gap-2">
            🏆 Mô Hình Kinh Doanh Nhóm VN30
          </h2>
          <p class="text-sm text-muted-foreground mt-1">Chuỗi giá trị và hoạt động của 30 doanh nghiệp niêm yết hàng đầu thị trường Việt Nam.</p>
        </div>
        <a href="/companies" class="text-sm font-semibold text-primary hover:underline flex items-center gap-1">
          Xem tất cả ({totalCount}) &rarr;
        </a>
      </div>
      
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {vn30Companies.map((c) => (
          <div class="bg-card border border-border rounded-2xl p-5 flex flex-col justify-between gap-4 shadow-sm hover:shadow-md hover:border-primary transition-all duration-300 transform hover:-translate-y-0.5">
            <div class="flex flex-col gap-2">
              <div class="flex justify-between items-start">
                <span class="font-display font-extrabold text-sm text-primary bg-primary/10 border border-primary/20 px-2.5 py-1 rounded-lg">{c.symbol}</span>
                <span class="text-[10px] font-extrabold px-2 py-0.5 rounded border border-border text-rose-500 bg-rose-500/5 border-rose-500/20">{c.exchange}</span>
              </div>
              <h3 class="text-sm font-bold text-foreground leading-snug tracking-tight mt-1">{c.name}</h3>
              <span class="text-xs font-semibold text-muted-foreground">{c.industry || 'Chưa phân ngành'}</span>
            </div>
            
            <div class="flex flex-wrap gap-1.5 mt-2">
              {c.hasBusinessModel && <span class="text-[9px] font-extrabold px-1.5 py-0.5 rounded bg-emerald-500/10 text-emerald-600 border border-emerald-500/20">CHUỖI GIÁ TRỊ</span>}
              {c.docCount > 0 && <span class="text-[9px] font-extrabold px-1.5 py-0.5 rounded bg-blue-500/10 text-blue-600 border border-blue-500/20">BCTC AI</span>}
              {c.hasResearch && <span class="text-[9px] font-extrabold px-1.5 py-0.5 rounded bg-amber-500/10 text-amber-600 border border-amber-500/20">SSI RESEARCH</span>}
            </div>
            
            <a href={`/companies/${c.symbol}`} class="w-full bg-muted border border-border text-foreground hover:bg-primary hover:text-primary-foreground hover:border-primary text-center py-2 rounded-lg text-xs font-bold transition-all duration-200 mt-2 min-h-[38px] flex items-center justify-center">
              Xem mô hình kinh doanh &rarr;
            </a>
          </div>
        ))}
      </div>
    </section>

    <!-- Research Feed Section (SSI Research Gated) -->
    <section class="flex flex-col gap-6">
      <div class="flex items-center justify-between border-l-4 border-primary pl-4">
        <h2 class="text-2xl font-bold text-foreground font-display">Nghiên cứu của SSI Research</h2>
        <a href="/research" class="text-sm font-semibold text-primary hover:underline flex items-center gap-1">
          Xem tất cả &rarr;
        </a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {researchFeed.map((item) => (
          <div class="bg-card border border-border rounded-2xl p-6 relative overflow-hidden flex flex-col gap-4 shadow-sm hover:shadow-md hover:border-primary transition-all duration-200">
            <div class="flex flex-col gap-2">
              <span class="inline-flex self-start text-xs font-bold px-2 py-1 rounded bg-primary/10 text-primary">
                <a href={`/companies/${item.symbol}`}>{item.symbol}</a>
              </span>
              <h3 class="text-base font-bold text-foreground font-display">Báo cáo phân tích chuyên sâu {item.symbol}</h3>
              <p class="text-sm text-muted-foreground leading-relaxed line-clamp-3 min-h-[4.5rem] mt-1">
                {item.ssiReview || item.summary || 'Thông tin đánh giá chi tiết chưa được cập nhật.'}
              </p>
              <span class="text-xs text-muted-foreground mt-2">
                Cập nhật: {item.lastUpdated ? new Date(item.lastUpdated).toLocaleDateString('vi-VN') : ''}
              </span>
            </div>
            
            <!-- Auth Gate Real SSR Block + Premium Lock UI -->
            {!isLoggedIn && (
              <div class="absolute inset-0 bg-slate-950/85 backdrop-blur-md flex flex-col items-center justify-center gap-3 p-6 text-center z-10 transition-opacity">
                <div class="w-12 h-12 bg-primary/20 text-primary rounded-full flex items-center justify-center text-xl font-bold shadow-md border border-primary/30">
                  🔒
                </div>
                <p class="text-white text-sm font-bold tracking-wide">
                  Tài liệu Nghiên cứu của SSI Research yêu cầu tài khoản bảo mật.
                </p>
                <p class="text-slate-400 text-xs max-w-xs">
                  Vui lòng liên hệ Admin Lúa Hóa để được cấp quyền đăng nhập.
                </p>
                <a href="/login" class="mt-2 bg-gradient-to-r from-primary to-blue-600 text-white font-bold text-sm px-6 py-2.5 rounded-full shadow-lg hover:shadow-primary/30 hover:scale-105 transition-all duration-200 min-h-[44px] flex items-center justify-center">
                  Đăng nhập hệ thống
                </a>
              </div>
            )}
          </div>
        ))}
        {researchFeed.length === 0 && (
          <div class="col-span-full py-12 text-center text-muted-foreground border border-dashed border-border rounded-2xl bg-card">
            Chưa có báo cáo nghiên cứu SSI mới.
          </div>
        )}
      </div>
    </section>
  </div>

  <!-- Client-side Auto-complete script -->
  <script is:inline>
    function removeVietnameseTones(str) {
      return str
        .normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '')
        .replace(/đ/g, 'd')
        .replace(/Đ/g, 'd')
        .toLowerCase();
    }

    function filterCompanies(query, companies) {
      const trimmed = query.trim().toLowerCase();
      if (!trimmed) return [];
      
      const normalizedQuery = removeVietnameseTones(trimmed);

      const filtered = companies.filter(company => {
        const symbolMatch = company.symbol.toLowerCase().includes(trimmed);
        const nameMatch = company.name.toLowerCase().includes(trimmed);
        
        const normalizedSymbol = removeVietnameseTones(company.symbol);
        const normalizedName = removeVietnameseTones(company.name);
        const normalizedMatch = normalizedSymbol.includes(normalizedQuery) || normalizedName.includes(normalizedQuery);

        return symbolMatch || nameMatch || normalizedMatch;
      });

      return filtered.slice(0, 8);
    }

    document.addEventListener('DOMContentLoaded', () => {
      const searchWrapper = document.getElementById('search-box-wrapper');
      if (!searchWrapper) return;

      const companies = JSON.parse(searchWrapper.getAttribute('data-companies') || '[]');
      const input = document.getElementById('search-input');
      const dropdown = document.getElementById('autocomplete-dropdown');
      const resultsContainer = document.getElementById('dropdown-results');
      const clearBtn = document.getElementById('clear-search');
      
      let activeIndex = -1;
      let currentItems = [];

      const renderDropdown = (items) => {
        currentItems = items;
        if (items.length === 0) {
          dropdown.classList.add('hidden');
          return;
        }

        resultsContainer.innerHTML = items.map((item, index) => `
          <div class="flex items-center justify-between px-5 py-4 cursor-pointer border-b border-border last:border-b-0 hover:bg-muted/80 transition-colors autocomplete-item" data-symbol="${item.symbol}" data-index="${index}">
            <div class="flex flex-col gap-0.5 items-start">
              <span class="font-display font-extrabold text-primary text-lg">${item.symbol}</span>
              <span class="text-sm font-semibold text-muted-foreground">${item.name}</span>
            </div>
            <div class="flex gap-2 items-center">
              <span class="text-xs font-bold px-2 py-0.5 rounded border border-border bg-muted ${item.exchange === 'HOSE' ? 'text-rose-500 bg-rose-500/5 border-rose-500/20' : item.exchange === 'HNX' ? 'text-blue-500 bg-blue-500/5 border-blue-500/20' : 'text-slate-500'}">${item.exchange}</span>
              <span class="text-xs font-medium text-muted-foreground">${item.industry || ''}</span>
            </div>
          </div>
        `).join('');

        dropdown.classList.remove('hidden');
        activeIndex = -1;

        // Click handlers on items
        document.querySelectorAll('.autocomplete-item').forEach(el => {
          el.addEventListener('click', () => {
            const symbol = el.getAttribute('data-symbol');
            window.location.href = `/companies/${symbol}`;
          });
        });
      };

      input.addEventListener('input', (e) => {
        const query = e.target.value;
        
        if (query) {
          clearBtn.classList.remove('hidden');
          clearBtn.classList.add('flex');
          const filtered = filterCompanies(query, companies);
          renderDropdown(filtered);
        } else {
          clearBtn.classList.add('hidden');
          clearBtn.classList.remove('flex');
          dropdown.classList.add('hidden');
        }
      });

      clearBtn.addEventListener('click', () => {
        input.value = '';
        clearBtn.classList.add('hidden');
        clearBtn.classList.remove('flex');
        dropdown.classList.add('hidden');
        input.focus();
      });

      // Key navigation in dropdown
      input.addEventListener('keydown', (e) => {
        const items = document.querySelectorAll('.autocomplete-item');
        if (items.length === 0) return;

        if (e.key === 'ArrowDown') {
          e.preventDefault();
          activeIndex = (activeIndex + 1) % items.length;
          updateActiveItem(items);
        } else if (e.key === 'ArrowUp') {
          e.preventDefault();
          activeIndex = (activeIndex - 1 + items.length) % items.length;
          updateActiveItem(items);
        } else if (e.key === 'Enter') {
          e.preventDefault();
          if (activeIndex >= 0 && activeIndex < items.length) {
            const selectedEl = items[activeIndex];
            const symbol = selectedEl.getAttribute('data-symbol');
            window.location.href = `/companies/${symbol}`;
          } else if (items.length > 0) {
            const symbol = items[0].getAttribute('data-symbol');
            window.location.href = `/companies/${symbol}`;
          }
        } else if (e.key === 'Escape') {
          dropdown.classList.add('hidden');
        }
      });

      function updateActiveItem(items) {
        items.forEach((item, index) => {
          if (index === activeIndex) {
            item.classList.add('bg-muted');
            item.scrollIntoView({ block: 'nearest' });
          } else {
            item.classList.remove('bg-muted');
          }
        });
      }

      document.addEventListener('click', (e) => {
        if (!searchWrapper.contains(e.target)) {
          dropdown.classList.add('hidden');
        }
      });
    });
  </script>
</Layout>
