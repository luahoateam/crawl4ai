---
import Layout from '../layouts/Layout.astro';
import { fetchCompanies, fetchStats, fetchGlobalNews, fetchGlobalDocuments, fetchGlobalResearch } from '../lib/api';

let companies = [];
let stats = { companies: 1617, businessModels: 1429, dailyResearch: 560, news: 14888, documents: 18185 };
let newsFeed = [];
let researchFeed = [];
let docsFeed = [];
let errorMsg = "";

// Check auth token
const token = Astro.cookies.get('token')?.value;
const isLoggedIn = !!token;

try {
  companies = await fetchCompanies();
} catch (e: any) {
  errorMsg = e.message;
  // Fallback mock companies for premium offline/error resilience
  companies = [
    { symbol: 'HPG', name: 'Tập đoàn Hòa Phát', exchange: 'HOSE', industry: 'Thép' },
    { symbol: 'HSG', name: 'Tập đoàn Hòa Phát', exchange: 'HOSE', industry: 'Thép' },
    { symbol: 'VCB', name: 'Ngân hàng Vietcombank', exchange: 'HOSE', industry: 'Ngân hàng' },
    { symbol: 'ACB', name: 'Ngân hàng ACB', exchange: 'HNX', industry: 'Ngân hàng' },
    { symbol: 'VND', name: 'Chứng khoán VNDirect', exchange: 'HOSE', industry: 'Chứng khoán' },
    { symbol: 'SSI', name: 'Chứng khoán SSI', exchange: 'HOSE', industry: 'Chứng khoán' },
    { symbol: 'FPT', name: 'Tập đoàn FPT', exchange: 'HOSE', industry: 'Công nghệ' },
    { symbol: 'MWG', name: 'Thế Giới Di Động', exchange: 'HOSE', industry: 'Bán lẻ' },
    { symbol: 'VNM', name: 'Sữa Việt Nam (Vinamilk)', exchange: 'HOSE', industry: 'Thực phẩm' },
    { symbol: 'VIC', name: 'Tập đoàn Vingroup', exchange: 'HOSE', industry: 'Bất động sản' }
  ];
}

try {
  stats = await fetchStats();
} catch (e) {}

try {
  const newsRes = await fetchGlobalNews({ perPage: 6 });
  newsFeed = newsRes.result || [];
} catch (e) {}

try {
  const researchRes = await fetchGlobalResearch({ perPage: 4 });
  researchFeed = researchRes.result || [];
} catch (e) {}

try {
  const docsRes = await fetchGlobalDocuments({ perPage: 4 });
  docsFeed = docsRes.result || [];
} catch (e) {}

const totalCount = stats.companies;
const hoseCount = companies.filter(c => c.exchange === 'HOSE').length || 423;
const hnxCount = companies.filter(c => c.exchange === 'HNX').length || 342;
const upcomCount = companies.filter(c => c.exchange === 'UPCOM').length || 646;
---

<Layout title="Stock Portal - Tra cứu doanh nghiệp & Chuỗi giá trị Việt Nam">
  <div class="homepage">
    <!-- Hero Section -->
    <section class="hero">
      <div class="container hero-container">
        <div class="badge-animated">Tra cứu mô hình kinh doanh & chuỗi giá trị</div>
        <h1 class="hero-title">
          <span>Khám Phá Sức Mạnh</span>
          <span class="gradient-text">Doanh Nghiệp Việt</span>
        </h1>
        <p class="hero-desc">
          Phân tích chuỗi giá trị (Value Chain), dòng doanh thu, chi phí sản xuất, tin tức cập nhật và tài liệu tài chính của hơn {totalCount} doanh nghiệp niêm yết.
        </p>

        <!-- Search Auto-complete Component -->
        <div class="search-box-wrapper" id="search-box-wrapper" data-companies={JSON.stringify(companies)}>
          <div class="search-input-container">
            <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <input 
              type="text" 
              id="search-input" 
              placeholder="Nhập mã cổ phiếu (ví dụ: HPG, VCB, FPT...) hoặc tên ngành..." 
              autocomplete="off"
            />
            <button id="clear-search" class="clear-search-btn" style="display: none;">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="18" height="18">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
              </svg>
            </button>
          </div>
          <!-- Dropdown items -->
          <div class="autocomplete-dropdown" id="autocomplete-dropdown" style="display: none;">
            <div class="dropdown-header">Kết quả gợi ý</div>
            <div class="dropdown-results" id="dropdown-results"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats Section -->
    <section class="stats-section">
      <div class="container grid-stats">
        <div class="stat-card">
          <div class="stat-num gradient-text stat-companies">{totalCount}</div>
          <div class="stat-label">Tổng doanh nghiệp niêm yết</div>
        </div>
        <div class="stat-card">
          <div class="stat-num">{hoseCount}</div>
          <div class="stat-label">Cổ phiếu sàn HOSE</div>
        </div>
        <div class="stat-card">
          <div class="stat-num">{hnxCount}</div>
          <div class="stat-label">Cổ phiếu sàn HNX</div>
        </div>
        <div class="stat-card">
          <div class="stat-num">{upcomCount}</div>
          <div class="stat-label">Cổ phiếu sàn UPCOM</div>
        </div>
      </div>
    </section>

    <!-- News Feed Section -->
    <section class="news-feed-section container">
      <h2 class="section-title">Tin Tức Mới Nhất</h2>
      <div class="grid-news">
        {newsFeed.map((item) => (
          <div class="news-card">
            <span class="news-badge-symbol">
              <a href={`/companies/${item.symbol}`}>{item.symbol}</a>
            </span>
            <h3 class="news-title">
              <a href={item.sourceUrl || '#'} target="_blank" rel="noopener noreferrer">{item.title}</a>
            </h3>
            <span class="news-time">
              {item.publishedDate ? new Date(item.publishedDate).toLocaleDateString('vi-VN') : new Date(item.createdAt).toLocaleDateString('vi-VN')}
            </span>
          </div>
        ))}
        {newsFeed.length === 0 && (
          <p class="empty-feed">Chưa có tin tức mới.</p>
        )}
      </div>
    </section>

    <!-- Research Feed Section -->
    <section class="research-feed-section container">
      <h2 class="section-title">Báo Cáo Nghiên Cứu Mới Nhất</h2>
      <div class="grid-research">
        {researchFeed.map((item) => (
          <div class="research-card">
            <div class="research-card-content">
              <span class="res-badge-symbol">
                <a href={`/companies/${item.symbol}`}>{item.symbol}</a>
              </span>
              <h3 class="res-title">Báo cáo phân tích chuyên sâu {item.symbol}</h3>
              <p class="res-summary">{item.summary || 'Thông tin đánh giá chi tiết chưa được cập nhật.'}</p>
              <span class="res-time">
                {item.lastUpdated ? new Date(item.lastUpdated).toLocaleDateString('vi-VN') : ''}
              </span>
            </div>
            {!isLoggedIn && (
              <div class="auth-gate-overlay">
                <div class="lock-icon">🔒</div>
                <p>Hội viên mới có thể xem đầy đủ báo cáo</p>
                <a href="/login" class="btn-login-cta">Đăng nhập</a>
              </div>
            )}
          </div>
        ))}
        {researchFeed.length === 0 && (
          <p class="empty-feed">Chưa có báo cáo nghiên cứu mới.</p>
        )}
      </div>
    </section>

    <!-- Documents Section (widget-docs) -->
    <section class="widget-docs container">
      <h2 class="section-title">Tài Liệu OCR Mới Nhất</h2>
      <div class="grid-docs">
        {docsFeed.map((item) => (
          <div class="doc-card">
            <span class="doc-badge-symbol">
              <a href={`/companies/${item.symbol}`}>{item.symbol}</a>
            </span>
            <h3 class="doc-title">{item.fileName}</h3>
            <div class="doc-meta">
              <span class="doc-year">Năm {item.year}</span>
              <span class="doc-label">{item.label || 'Tài liệu'}</span>
            </div>
            <a href={item.fileUrl} class="doc-view-btn" target="_blank" rel="noopener noreferrer">Xem OCR</a>
          </div>
        ))}
        {docsFeed.length === 0 && (
          <p class="empty-feed">Chưa có tài liệu mới.</p>
        )}
      </div>
    </section>
  </div>

  <style>
    .homepage {
      display: flex;
      flex-direction: column;
      gap: 4rem;
      padding-bottom: 4rem;
    }

    .hero {
      position: relative;
      padding: 5rem 0 2rem;
      text-align: center;
      overflow: hidden;
    }

    .hero-container {
      max-width: 900px;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1.5rem;
    }

    .badge-animated {
      font-size: 0.85rem;
      font-weight: 600;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      padding: 0.5rem 1.25rem;
      background: var(--bg-tertiary);
      border: 1px solid var(--border-color);
      border-radius: 9999px;
      color: var(--accent-primary);
      box-shadow: var(--shadow-sm);
      animation: float 3s ease-in-out infinite;
    }

    .hero-title {
      font-size: clamp(2rem, 8vw, 4.25rem);
      font-weight: 800;
      letter-spacing: -0.03em;
      line-height: 1.15;
      display: flex;
      flex-direction: column;
      gap: 0.25rem;
    }

    .gradient-text {
      background: var(--accent-gradient);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      display: inline-block;
    }

    .hero-desc {
      font-size: 1.125rem;
      color: var(--text-secondary);
      max-width: 650px;
      line-height: 1.75;
      margin-bottom: 1.5rem;
    }

    /* Search Auto-complete styles */
    .search-box-wrapper {
      position: relative;
      width: 100%;
      max-width: 650px;
      z-index: 10;
    }

    .search-input-container {
      position: relative;
      display: flex;
      align-items: center;
      background: var(--bg-secondary);
      border: 2px solid var(--border-color);
      border-radius: 9999px;
      padding: 0.25rem 0.5rem;
      box-shadow: var(--shadow-md);
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .search-input-container:focus-within {
      border-color: var(--accent-primary);
      box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.15);
      transform: translateY(-2px);
    }

    .search-icon {
      width: 22px;
      height: 22px;
      color: var(--text-muted);
      margin-left: 1.25rem;
      flex-shrink: 0;
    }

    #search-input {
      width: 100%;
      border: none;
      background: transparent;
      padding: 0.85rem 1rem;
      font-size: 1.05rem;
      color: var(--text-primary);
      font-family: var(--font-sans);
      outline: none;
    }

    #search-input::placeholder {
      color: var(--text-muted);
    }

    .clear-search-btn {
      background: transparent;
      border: none;
      color: var(--text-muted);
      cursor: pointer;
      padding: 0.5rem;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 50%;
      margin-right: 0.75rem;
      transition: background-color 0.2s ease;
    }

    .clear-search-btn:hover {
      background-color: var(--bg-tertiary);
      color: var(--text-primary);
    }

    .autocomplete-dropdown {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      margin-top: 0.75rem;
      background: var(--bg-secondary);
      border: 1px solid var(--border-color);
      border-radius: 16px;
      box-shadow: var(--shadow-lg);
      text-align: left;
      overflow: hidden;
      animation: slideDown 0.2s ease-out;
    }

    .dropdown-header {
      padding: 0.75rem 1.25rem;
      font-size: 0.75rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: var(--text-muted);
      border-bottom: 1px solid var(--border-color);
      background-color: var(--bg-tertiary);
    }

    .dropdown-results {
      max-height: 380px;
      overflow-y: auto;
    }

    /* Autocomplete Item styles */
    .autocomplete-item {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 1rem 1.25rem;
      cursor: pointer;
      border-bottom: 1px solid var(--border-color);
      transition: all 0.15s ease;
    }

    .autocomplete-item:last-child {
      border-bottom: none;
    }

    .autocomplete-item:hover, .autocomplete-item.active {
      background-color: var(--bg-tertiary);
    }

    .item-left {
      display: flex;
      flex-direction: column;
      gap: 0.15rem;
      align-items: flex-start;
    }

    .item-symbol {
      font-family: var(--font-display);
      font-weight: 800;
      color: var(--accent-primary);
      font-size: 1.1rem;
    }

    .item-name {
      font-size: 0.9rem;
      color: var(--text-secondary);
      font-weight: 500;
    }

    .item-right {
      display: flex;
      gap: 0.5rem;
      align-items: center;
    }

    .badge-exchange {
      font-size: 0.75rem;
      font-weight: 700;
      padding: 0.2rem 0.5rem;
      border-radius: 4px;
      background: var(--bg-tertiary);
      color: var(--text-muted);
      border: 1px solid var(--border-color);
    }

    .badge-exchange.HOSE {
      background: rgba(239, 68, 68, 0.1);
      color: #ef4444;
      border-color: rgba(239, 68, 68, 0.2);
    }

    .badge-exchange.HNX {
      background: rgba(59, 130, 246, 0.1);
      color: #3b82f6;
      border-color: rgba(59, 130, 246, 0.2);
    }

    .badge-industry {
      font-size: 0.75rem;
      font-weight: 500;
      color: var(--text-muted);
    }

    /* Stats Section styles */
    .stats-section {
      padding: 2rem 0;
    }

    .grid-stats {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    @media (min-width: 576px) {
      .grid-stats {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (min-width: 992px) {
      .grid-stats {
        grid-template-columns: repeat(4, 1fr);
      }
    }

    .stat-card {
      background: var(--bg-secondary);
      border: 1px solid var(--border-color);
      border-radius: 16px;
      padding: 2rem 1.5rem;
      text-align: center;
      box-shadow: var(--shadow-sm);
      transition: all 0.3s ease;
    }

    .stat-card:hover {
      transform: translateY(-5px);
      box-shadow: var(--shadow-md);
      border-color: var(--accent-primary);
    }

    .stat-num {
      font-family: var(--font-display);
      font-size: 2.25rem;
      font-weight: 800;
      color: var(--text-primary);
      margin-bottom: 0.5rem;
    }

    .stat-label {
      font-size: 0.9rem;
      color: var(--text-secondary);
      font-weight: 500;
    }

    /* Common Section Styles */
    .section-title {
      font-size: 1.75rem;
      font-weight: 700;
      color: var(--text-primary);
      margin-bottom: 1.5rem;
      position: relative;
      padding-left: 1rem;
    }
    .section-title::before {
      content: '';
      position: absolute;
      left: 0;
      top: 0.25rem;
      bottom: 0.25rem;
      width: 4px;
      background: var(--accent-gradient);
      border-radius: 2px;
    }

    .empty-feed {
      color: var(--text-muted);
      text-align: center;
      grid-column: 1 / -1;
      padding: 2rem;
      background: var(--bg-secondary);
      border: 1px dashed var(--border-color);
      border-radius: 12px;
    }

    /* News Feed Section */
    .grid-news {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1rem;
    }
    @media (min-width: 768px) {
      .grid-news {
        grid-template-columns: repeat(2, 1fr);
      }
    }
    @media (min-width: 1024px) {
      .grid-news {
        grid-template-columns: repeat(3, 1fr);
      }
    }
    .news-card {
      background: var(--bg-secondary);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 1.25rem;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      transition: all 0.2s ease;
      position: relative;
    }
    .news-card:hover {
      border-color: var(--accent-primary);
      transform: translateY(-2px);
    }
    .news-badge-symbol, .res-badge-symbol, .doc-badge-symbol {
      align-self: flex-start;
      font-size: 0.75rem;
      font-weight: 700;
      padding: 0.2rem 0.5rem;
      border-radius: 4px;
      background: rgba(59, 130, 246, 0.1);
      color: var(--accent-primary);
    }
    .news-badge-symbol a, .res-badge-symbol a, .doc-badge-symbol a {
      color: inherit;
      text-decoration: none;
    }
    .news-title {
      font-size: 1rem;
      font-weight: 600;
      line-height: 1.4;
      margin: 0;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
      min-height: 2.8rem;
    }
    .news-title a {
      color: var(--text-primary);
      text-decoration: none;
      transition: color 0.15s ease;
    }
    .news-title a:hover {
      color: var(--accent-primary);
    }
    .news-time, .res-time {
      font-size: 0.8rem;
      color: var(--text-muted);
    }

    /* Research Feed Section */
    .grid-research {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    @media (min-width: 768px) {
      .grid-research {
        grid-template-columns: repeat(2, 1fr);
      }
    }
    .research-card {
      background: var(--bg-secondary);
      border: 1px solid var(--border-color);
      border-radius: 16px;
      padding: 1.5rem;
      position: relative;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      gap: 1rem;
      transition: all 0.2s ease;
    }
    .research-card:hover {
      border-color: var(--accent-primary);
      transform: translateY(-2px);
    }
    .research-card-content {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }
    .res-title {
      font-size: 1.1rem;
      font-weight: 700;
      margin: 0;
      color: var(--text-primary);
    }
    .res-summary {
      font-size: 0.9rem;
      color: var(--text-secondary);
      line-height: 1.5;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
      min-height: 4rem;
      margin: 0;
    }
    /* Auth Gate Overlay */
    .auth-gate-overlay {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: rgba(15, 23, 42, 0.65);
      backdrop-filter: blur(8px);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 0.75rem;
      padding: 1.5rem;
      text-align: center;
      z-index: 2;
    }
    .auth-gate-overlay p {
      color: #ffffff;
      font-size: 0.95rem;
      font-weight: 600;
      margin: 0;
      text-shadow: 0 2px 4px rgba(0,0,0,0.5);
    }
    .lock-icon {
      font-size: 1.75rem;
    }
    .btn-login-cta {
      background: var(--accent-gradient);
      color: #ffffff;
      font-weight: 700;
      font-size: 0.85rem;
      padding: 0.5rem 1.5rem;
      border-radius: 9999px;
      text-decoration: none;
      box-shadow: 0 4px 12px rgba(59, 130, 246, 0.3);
      transition: transform 0.2s ease;
    }
    .btn-login-cta:hover {
      transform: scale(1.05);
    }

    /* Documents Section (widget-docs) */
    .grid-docs {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }
    @media (min-width: 576px) {
      .grid-docs {
        grid-template-columns: repeat(2, 1fr);
      }
    }
    @media (min-width: 1024px) {
      .grid-docs {
        grid-template-columns: repeat(4, 1fr);
      }
    }
    .doc-card {
      background: var(--bg-secondary);
      border: 1px solid var(--border-color);
      border-radius: 14px;
      padding: 1.25rem;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      transition: all 0.2s ease;
    }
    .doc-card:hover {
      border-color: var(--accent-primary);
      transform: translateY(-2px);
    }
    .doc-title {
      font-size: 0.95rem;
      font-weight: 600;
      color: var(--text-primary);
      margin: 0;
      line-height: 1.4;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
      min-height: 2.7rem;
    }
    .doc-meta {
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 0.8rem;
      color: var(--text-muted);
    }
    .doc-label {
      background: var(--bg-tertiary);
      padding: 0.1rem 0.4rem;
      border-radius: 4px;
      border: 1px solid var(--border-color);
    }
    .doc-view-btn {
      margin-top: auto;
      background: var(--bg-tertiary);
      border: 1px solid var(--border-color);
      color: var(--text-primary);
      text-align: center;
      padding: 0.5rem;
      border-radius: 8px;
      font-size: 0.85rem;
      font-weight: 600;
      text-decoration: none;
      transition: all 0.2s ease;
    }
    .doc-view-btn:hover {
      background: var(--accent-primary);
      color: #ffffff;
      border-color: var(--accent-primary);
    }
  </style>

  <!-- Client-side Auto-complete script -->
  <script is:inline>
    // Robust search logic with Vietnamese tone removal
    function removeVietnameseTones(str) {
      return str
        .normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '')
        .replace(/đ/g, 'd')
        .replace(/Đ/g, 'd')
        .toLowerCase();
    }

    function filterCompanies(query, companies) {
      const trimmed = query.trim().toLowerCase();
      if (!trimmed) return [];
      
      const normalizedQuery = removeVietnameseTones(trimmed);

      const filtered = companies.filter(company => {
        const symbolMatch = company.symbol.toLowerCase().includes(trimmed);
        const nameMatch = company.name.toLowerCase().includes(trimmed);
        
        const normalizedSymbol = removeVietnameseTones(company.symbol);
        const normalizedName = removeVietnameseTones(company.name);
        const normalizedMatch = normalizedSymbol.includes(normalizedQuery) || normalizedName.includes(normalizedQuery);

        return symbolMatch || nameMatch || normalizedMatch;
      });

      return filtered.slice(0, 8);
    }

    document.addEventListener('DOMContentLoaded', () => {
      const searchWrapper = document.getElementById('search-box-wrapper');
      if (!searchWrapper) return;

      const companies = JSON.parse(searchWrapper.getAttribute('data-companies') || '[]');
      const input = document.getElementById('search-input');
      const dropdown = document.getElementById('autocomplete-dropdown');
      const resultsContainer = document.getElementById('dropdown-results');
      const clearBtn = document.getElementById('clear-search');
      
      let activeIndex = -1;
      let currentItems = [];

      const renderDropdown = (items) => {
        currentItems = items;
        if (items.length === 0) {
          dropdown.style.display = 'none';
          return;
        }

        resultsContainer.innerHTML = items.map((item, index) => `
          <div class="autocomplete-item" data-symbol="${item.symbol}" data-index="${index}">
            <div class="item-left">
              <span class="item-symbol">${item.symbol}</span>
              <span class="item-name">${item.name}</span>
            </div>
            <div class="item-right">
              <span class="badge-exchange ${item.exchange}">${item.exchange}</span>
              <span class="badge-industry">${item.industry || ''}</span>
            </div>
          </div>
        `).join('');

        dropdown.style.display = 'block';
        activeIndex = -1;

        // Click handlers on items
        document.querySelectorAll('.autocomplete-item').forEach(el => {
          el.addEventListener('click', () => {
            const symbol = el.getAttribute('data-symbol');
            window.location.href = `/companies/${symbol}`;
          });
        });
      };

      input.addEventListener('input', (e) => {
        const query = e.target.value;
        
        if (query) {
          clearBtn.style.display = 'flex';
          const filtered = filterCompanies(query, companies);
          renderDropdown(filtered);
        } else {
          clearBtn.style.display = 'none';
          dropdown.style.display = 'none';
        }
      });

      clearBtn.addEventListener('click', () => {
        input.value = '';
        clearBtn.style.display = 'none';
        dropdown.style.display = 'none';
        input.focus();
      });

      // Key navigation in dropdown
      input.addEventListener('keydown', (e) => {
        const items = document.querySelectorAll('.autocomplete-item');
        if (items.length === 0) return;

        if (e.key === 'ArrowDown') {
          e.preventDefault();
          activeIndex = (activeIndex + 1) % items.length;
          updateActiveItem(items);
        } else if (e.key === 'ArrowUp') {
          e.preventDefault();
          activeIndex = (activeIndex - 1 + items.length) % items.length;
          updateActiveItem(items);
        } else if (e.key === 'Enter') {
          e.preventDefault();
          if (activeIndex >= 0 && activeIndex < items.length) {
            const selectedEl = items[activeIndex];
            const symbol = selectedEl.getAttribute('data-symbol');
            window.location.href = `/companies/${symbol}`;
          } else if (items.length > 0) {
            // Pick the first item on Enter if none is selected
            const symbol = items[0].getAttribute('data-symbol');
            window.location.href = `/companies/${symbol}`;
          }
        } else if (e.key === 'Escape') {
          dropdown.style.display = 'none';
        }
      });

      function updateActiveItem(items) {
        items.forEach((item, index) => {
          if (index === activeIndex) {
            item.classList.add('active');
            item.scrollIntoView({ block: 'nearest' });
          } else {
            item.classList.remove('active');
          }
        });
      }

      // Close dropdown when clicking outside
      document.addEventListener('click', (e) => {
        if (!searchWrapper.contains(e.target)) {
          dropdown.style.display = 'none';
        }
      });
    });
  </script>
</Layout>
