---
import '../styles/global.css';
import ThemeToggle from '../components/ThemeToggle.astro';
import Logo from '../components/Logo.astro';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "Stock Portal - Tra cứu doanh nghiệp Việt Nam", 
  description = "Cổng thông tin tra cứu mô hình kinh doanh, tin tức và tài liệu tài chính của các doanh nghiệp niêm yết tại Việt Nam." 
} = Astro.props;
---

<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    
    <!-- Inline script to restore theme quickly and prevent flash -->
    <script is:inline>
      const savedTheme = localStorage.getItem('theme') || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      if (savedTheme === 'dark') {
        document.documentElement.setAttribute('data-theme', 'dark');
      } else {
        document.documentElement.removeAttribute('data-theme');
      }
    </script>
  </head>
  <body class="bg-background text-foreground font-sans min-h-screen flex flex-col antialiased selection:bg-primary/20 selection:text-primary transition-colors duration-300">
    <header class="sticky top-0 z-50 w-full border-b border-border bg-background/80 backdrop-blur-md transition-colors duration-300">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
        <Logo size="md" />
        
        <!-- Desktop Navigation -->
        <nav class="hidden md:flex items-center gap-1">
          <a href="/companies" class="px-4 py-2 text-sm font-medium rounded-md transition-all duration-200 text-muted-foreground hover:text-foreground hover:bg-muted/50 min-h-[44px] flex items-center">
            Mô hình kinh doanh
          </a>
          <a href="/documents" class="px-4 py-2 text-sm font-medium rounded-md transition-all duration-200 text-muted-foreground hover:text-foreground hover:bg-muted/50 min-h-[44px] flex items-center">
            Báo cáo tài chính cho AI đọc
          </a>
          <a href="/research" class="px-4 py-2 text-sm font-medium rounded-md transition-all duration-200 text-muted-foreground hover:text-foreground hover:bg-muted/50 min-h-[44px] flex items-center">
            Nghiên cứu SSI
          </a>
          <div class="ml-2">
            <ThemeToggle />
          </div>
        </nav>

        <!-- Mobile Navigation Trigger & Toggle -->
        <div class="flex items-center gap-2 md:hidden">
          <ThemeToggle />
          <button 
            id="mobile-menu-btn" 
            class="p-2 rounded-md text-muted-foreground hover:text-foreground hover:bg-muted/50 focus:outline-none min-h-[44px] min-w-[44px] flex items-center justify-center"
            aria-label="Toggle menu"
            aria-expanded="false"
          >
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>
      </div>

      <!-- Mobile Menu -->
      <div id="mobile-menu" class="hidden md:hidden border-b border-border bg-background px-4 py-3 space-y-1 transition-all duration-300">
        <a href="/companies" class="block px-4 py-3 text-base font-medium rounded-md text-muted-foreground hover:text-foreground hover:bg-muted transition-colors min-h-[44px]">
          Mô hình kinh doanh
        </a>
        <a href="/documents" class="block px-4 py-3 text-base font-medium rounded-md text-muted-foreground hover:text-foreground hover:bg-muted transition-colors min-h-[44px]">
          Báo cáo tài chính cho AI đọc
        </a>
        <a href="/research" class="block px-4 py-3 text-base font-medium rounded-md text-muted-foreground hover:text-foreground hover:bg-muted transition-colors min-h-[44px]">
          Nghiên cứu SSI
        </a>
      </div>
    </header>

    <main class="flex-grow py-8 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
      <slot />
    </main>

    <footer class="border-t border-border bg-card py-8 transition-colors duration-300">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col md:flex-row items-center justify-between gap-4 text-center md:text-left text-sm text-muted-foreground">
        <p>&copy; {new Date().getFullYear()} Lúa Hóa Team. All rights reserved.</p>
        <div class="flex gap-4">
          <a href="/companies" class="hover:text-foreground transition-colors">Mô hình kinh doanh</a>
          <a href="/documents" class="hover:text-foreground transition-colors">Tài liệu AI</a>
          <a href="/research" class="hover:text-foreground transition-colors">Nghiên cứu SSI</a>
        </div>
      </div>
    </footer>

    <script>
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      const menuIcon = document.getElementById('menu-icon');

      if (btn && menu) {
        btn.addEventListener('click', () => {
          const expanded = btn.getAttribute('aria-expanded') === 'true';
          btn.setAttribute('aria-expanded', String(!expanded));
          menu.classList.toggle('hidden');
          
          if (menuIcon) {
            if (!expanded) {
              // Show 'X' icon
              menuIcon.setAttribute('d', 'M6 18L18 6M6 6l12 12');
            } else {
              // Show hamburger icon
              menuIcon.setAttribute('d', 'M4 6h16M4 12h16M4 18h16');
            }
          }
        });
      }
    </script>
  </body>
</html>
